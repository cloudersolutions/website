---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import CasePost from '@components/CasePost.astro';
import Divider from '@components/Divider.astro';
import LogoRow from '@components/LogoRow.astro';
import Quote from '@components/Quote.astro';
import SiteFooter from '@components/SiteFooter.astro';
import SiteHeader from '@components/SiteHeader.astro';
import config from '@data/config.yml';
import { paths } from '@data/paths';
import { filterDrafts } from '@utils/content';
import OpexTable from '@assets/OpexTable.astro';
import FindingsUI from '@assets/FindingsUI.astro';
import ConsumptionUI from '@assets/ConsumptionUI.astro';
import heroVideoAv1 from '@assets/aerial.av1.mp4';
import heroVideoWebm from '@assets/aerial.webm';
import heroPoster from '@assets/poster.jpg';

const posts = await getCollection('news', filterDrafts);

const caseExamplePosts = posts
  .filter((post) => post.data.category === 'case-study')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout title={config.title} ogTitle={config.ogtitle} description={config.description}>
  <section class="relative bg-neutral-900 dark:bg-neutral-950">
    <div class="absolute inset-0 z-0 mask-linear-315 mask-linear-from-0%">
      <video
        aria-hidden="true"
        playsinline
        autoplay
        muted
        loop
        class="absolute inset-0 size-full object-cover"
        poster={heroPoster.src}
      >
        <source src={heroVideoAv1} type="video/mp4" />
        <source src={heroVideoWebm} type="video/webm" />
      </video>
    </div>
    <div class="relative">
      <SiteHeader
        headerClass="bg-transparent dark:bg-transparent text-neutral-50 dark:text-neutral-50"
        itemClass="hover:bg-current/10 active:bg-current/10 text-shadow-sm"
      />
      <div class="container py-28 lg:py-56">
        <div class="-mt-4 max-w-prose drop-shadow-[0_0_24px] drop-shadow-black/75">
          <h1 class="mb-6 font-serif text-5xl text-neutral-50 lg:text-6xl">
            Turn building data into investment-grade asset intelligence
          </h1>
          <p class="mb-8 text-xl text-balance text-neutral-50">
            Clouder’s asset intelligence unlocks hidden value in commercial real estate portfolios
            with industry specific AI agents.
          </p>
          <a
            href={paths.contact.href}
            class="inline-flex h-11 cursor-pointer items-center justify-center rounded bg-neutral-50 px-4.5 text-center text-nowrap text-neutral-950 shadow-xs transition select-none hover:bg-neutral-300 active:bg-neutral-300"
          >
            Get started today
          </a>
        </div>
      </div>
    </div>
  </section>
  <section>
    <div class="pt-16 pb-8 lg:pt-32 lg:pb-16">
      <div class="container">
        <p class="mb-5 text-xs font-medium tracking-wider text-neutral-500 uppercase lg:mb-6">
          The platform
        </p>
        <h2
          class="mb-4 font-serif text-4xl text-neutral-950 lg:mb-5 lg:text-5xl dark:text-neutral-50"
        >
          Your portfolio<br class="hidden lg:block" /> constantly optimized
        </h2>
        <div class="grid gap-8 lg:grid-cols-3">
          <div class="col-span-2">
            <p class="mb-4 text-balance">
              The critical difference: we connect directly to your building systems — not through
              cloud APIs. This means we don't just read data. We act on it, in real time, and learn
              from the result. Every building we operate gets smarter over time. Every new asset
              benefits from what we have already learned.
            </p>
            <p class="font-medium text-neutral-950 dark:text-neutral-50">
              You keep full visibility and control. We handle everything in between.
            </p>
          </div>
          <div class="text-right">
            <a
              href={paths.contact.href}
              class="inline-flex h-10 cursor-pointer items-center justify-center rounded bg-neutral-950 px-4 text-center text-sm text-nowrap text-neutral-50 transition select-none hover:bg-neutral-700 active:bg-neutral-700 dark:bg-neutral-50 dark:text-neutral-950 dark:hover:bg-neutral-300 dark:active:bg-neutral-300"
            >
              Book a free consultation
            </a>
          </div>
        </div>
      </div>
    </div>
    <div class="pb-16 lg:pb-32">
      <div class="container">
        <div class="grid gap-x-4 gap-y-8 lg:grid-cols-3">
          <div>
            <div
              class="relative aspect-square overflow-hidden bg-linear-to-b from-neutral-200 to-neutral-300 lg:aspect-3/4 dark:from-neutral-700 dark:to-neutral-800"
            >
              <div
                class="absolute inset-0 flex scale-85 flex-col items-center justify-center select-none xl:scale-100"
              >
                <ConsumptionUI />
              </div>
            </div>
            <p class="mt-4 mb-2 text-lg font-medium text-neutral-950 dark:text-neutral-50">
              Real-time reporting
            </p>
            <p class="text-balance">
              Energy agents create your energy and performance reports automatically from live meter
              data, always current, always accurate.
            </p>
          </div>
          <div>
            <div
              class="relative aspect-square overflow-hidden bg-linear-to-b from-neutral-200 to-neutral-300 lg:aspect-3/4 dark:from-neutral-700 dark:to-neutral-800"
            >
              <div
                class="group absolute inset-0 flex scale-85 flex-col items-center justify-center gap-3 select-none sm:left-0 xl:scale-100"
              >
                <FindingsUI
                  title="Consumption levels normalised after scheduling fix"
                  status="ok"
                />
                <div
                  class="-z-1 -mt-21.5 scale-95 transition-all duration-300 group-hover:mt-0 group-hover:scale-100 group-hover:opacity-100 group-active:mt-0 group-active:scale-100 group-active:opacity-100"
                >
                  <FindingsUI
                    title="Suboptimal conditions for tenants in Zone A"
                    status="warning"
                  />
                </div>
                <div
                  class="-z-2 -mt-17.75 scale-90 transition-all duration-300 group-hover:mt-0 group-hover:scale-100 group-hover:opacity-100 group-active:mt-0 group-active:scale-100 group-active:opacity-100"
                >
                  <FindingsUI title="Air handling unit 3o6 bus fault" status="error" />
                </div>
              </div>
            </div>
            <p class="mt-4 mb-2 text-lg font-medium text-neutral-950 dark:text-neutral-50">
              Autonomous fault detection
            </p>
            <p class="text-balance">
              Our platform assesses the building’s performance constantly against its target
              behavior and alerts maintenance the moment something needs fixing before it becomes a
              complaint. Cutting energy waste and costs.
            </p>
          </div>
          <div>
            <div
              class="relative aspect-square overflow-hidden bg-linear-to-b from-neutral-200 to-neutral-300 lg:aspect-3/4 dark:from-neutral-700 dark:to-neutral-800"
            >
              <div
                class="group absolute inset-0 flex scale-85 flex-col items-center justify-center select-none xl:scale-100"
              >
                <div
                  class="relative rounded-3xl bg-neutral-100 p-4 shadow-xl shadow-black/5 dark:bg-neutral-700"
                >
                  <svg
                    width="64"
                    height="64"
                    viewBox="0 0 64 64"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                    class="shrink-0"
                  >
                    <rect width="64" height="64" rx="14" fill="black"></rect>
                    <path
                      fill-rule="evenodd"
                      clip-rule="evenodd"
                      d="M16 33C16 22.5066 24.5066 14 35 14H46V20H35C27.8203 20 22 25.8203 22 33C22 40.1797 27.8203 46 35 46H46V52H35C24.5066 52 16 43.4934 16 33Z"
                      fill="white"></path>
                  </svg>
                  <div
                    class="absolute top-2 right-2 flex size-5 scale-0 items-center justify-center rounded-full bg-red-500 opacity-0 transition duration-300 group-hover:scale-100 group-hover:opacity-100 group-active:scale-100 group-active:opacity-100"
                  >
                    <span class="text-[10px] leading-none font-medium text-white">1</span>
                  </div>
                </div>
              </div>
            </div>
            <p class="mt-4 mb-2 text-lg font-medium text-neutral-950 dark:text-neutral-50">
              Commissioning verification
            </p>
            <p class="text-balance">
              In renovations and new developments, we give you real-time confirmation that the
              building is being commissioned correctly and it runs efficiently from day one.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <Divider />
  <section>
    <div class="py-16 lg:py-32">
      <div class="container">
        <div class="grid gap-x-4 gap-y-8 lg:grid-cols-2 lg:gap-x-8">
          <div>
            <p class="mb-5 text-xs font-medium tracking-wider text-neutral-500 uppercase lg:mb-6">
              The value case
            </p>
            <h2
              class="mb-4 font-serif text-3xl text-neutral-950 lg:mb-5 lg:text-5xl dark:text-neutral-50"
            >
              What asset intelligence does to your portfolio
            </h2>
            <p class="mb-4 text-balance">
              Commercial real estate portfolios carry significant unrealised value. Not from market
              movements, but from operational friction that has never been measured. Research from
              McKinsey, JLL, and Morgan Stanley puts the recoverable opportunity at 10–30% of total
              opex.
            </p>
            <p class="mb-6 font-medium text-neutral-950 dark:text-neutral-50">
              We make it visible, then we eliminate it.
            </p>
            <a
              href={paths.contact.href}
              class="inline-flex h-10 cursor-pointer items-center justify-center rounded bg-neutral-950 px-4 text-center text-sm text-nowrap text-neutral-50 transition select-none hover:bg-neutral-700 active:bg-neutral-700 dark:bg-neutral-50 dark:text-neutral-950 dark:hover:bg-neutral-300 dark:active:bg-neutral-300"
            >
              Get started today
            </a>
          </div>
          <div
            class="bg-linear-to-b from-neutral-200 to-neutral-300 p-8 pb-6 lg:p-12 lg:pb-8 dark:from-neutral-700 dark:to-neutral-800"
          >
            <OpexTable />
          </div>
        </div>
      </div>
    </div>
    <div class="pb-16 lg:pb-32">
      <div class="container">
        <div class="grid gap-x-8 gap-y-12 lg:grid-cols-2">
          <Quote
            quote="With our high-value property, we didn’t want to spend the first year figuring it out. Clouder gave us the transparency we needed to address our data debt upfront, ensuring the building was optimized before the first tenant even walked through the door."
            citeName="Hannu Tammia"
            citeTitle="Asset Manager"
            citeCompany="areim"
          />
          <Quote
            quote="As we take responsibility for building operations and costs for 20 years, data is mission-critical. With Clouder, we’re able to collect data comprehensively and cost-efficiently to ensure optimal conditions while keeping operational costs low."
            citeName="Jere Pirhonen"
            citeTitle="Director, Energy and Lifecycle Services"
            citeCompany="srv"
          />
        </div>
      </div>
    </div>
    <div class="pb-16 lg:pb-32">
      <div class="container">
        <p class="mb-2 text-center text-xs font-medium tracking-wider text-neutral-500 uppercase">
          Trusted by
        </p>
        <LogoRow />
      </div>
    </div>
    <Divider />
    <section>
      <div class="py-16 lg:py-32">
        <div class="container">
          <div class="grid gap-x-4 gap-y-8 lg:grid-cols-3 lg:gap-x-8">
            <div class="col-span-full">
              <p class="mb-5 text-xs font-medium tracking-wider text-neutral-500 uppercase lg:mb-6">
                How it works
              </p>
              <h2 class="font-serif text-4xl text-neutral-950 lg:text-5xl dark:text-neutral-50">
                Simple engagement.<br class="hidden lg:block" /> Fast time to value.
              </h2>
            </div>
            <div class="space-y-1">
              <p class="text-sm font-medium text-neutral-500">01</p>
              <p class="text-lg font-medium text-neutral-950 dark:text-neutral-50">Assesment</p>
              <p class="text-balance">
                We assess your assets and quantify exactly what is being left on the table.
              </p>
            </div>
            <div class="space-y-1">
              <p class="text-sm font-medium text-neutral-500">02</p>
              <p class="text-lg font-medium text-neutral-950 dark:text-neutral-50">
                Proof of value
              </p>
              <p class="text-balance">
                We connect the data, close the gaps, and deliver measurable NOI improvement on a
                single asset.
              </p>
            </div>
            <div class="space-y-1">
              <p class="text-sm font-medium text-neutral-500">03</p>
              <p class="text-lg font-medium text-neutral-950 dark:text-neutral-50">Scaling</p>
              <p class="text-balance">
                AI agents, automatic reporting, and continuous optimisation from day one.
              </p>
            </div>
            <div class="space-y-1 lg:col-span-2">
              <p class="text-sm font-medium text-neutral-500">↺</p>
              <p class="text-lg font-medium text-neutral-950 dark:text-neutral-50">Roll it out</p>
              <p class="text-balance">The same loop across your assets with compounding results.</p>
            </div>
            <div class="my-auto">
              <a
                href={paths.contact.href}
                class="inline-flex h-10 cursor-pointer items-center justify-center rounded bg-neutral-950 px-4 text-center text-sm text-nowrap text-neutral-50 transition select-none hover:bg-neutral-700 active:bg-neutral-700 dark:bg-neutral-50 dark:text-neutral-950 dark:hover:bg-neutral-300 dark:active:bg-neutral-300"
              >
                Get in touch
              </a>
            </div>
          </div>
        </div>
      </div>
      {
        caseExamplePosts.length > 0 && (
          <div class="pb-16 lg:pb-32">
            <div class="container">
              <div class="flex items-baseline justify-between">
                <h3 class="text-xs font-medium tracking-wider text-neutral-500 uppercase">
                  Results from our customers
                </h3>
                <a
                  class="group text-sm text-neutral-500 transition hover:text-current active:text-current"
                  href={`${paths.news.href}/case-study`}
                >
                  Case studies
                  <span class="inline-block opacity-60 transition group-hover:translate-x-0.5 group-hover:opacity-100">
                    &rarr;
                  </span>
                </a>
              </div>
              <div class="mt-8 flex flex-col gap-8 lg:flex-row">
                {caseExamplePosts.map((post) => (
                  <CasePost post={post} />
                ))}
              </div>
            </div>
          </div>
        )
      }
    </section>
    <SiteFooter />
  </section>
</BaseLayout>
