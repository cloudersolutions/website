---
import { getCollection } from 'astro:content';
import TargetIcon from 'lucide-astro/Target';
import ZapIcon from 'lucide-astro/Zap';
import ChartColumnIcon from 'lucide-astro/ChartColumn';
import RepeatIcon from 'lucide-astro/RotateCcw';
import BaseLayout from '@layouts/BaseLayout.astro';
import QuotePost from '@components/QuotePost.astro';
import Divider from '@components/Divider.astro';
import LogoRow from '@components/LogoRow.astro';
import SiteFooter from '@components/SiteFooter.astro';
import SiteHeader from '@components/SiteHeader.astro';
import config from '@data/config.yml';
import { paths } from '@data/paths';
import { filterDrafts } from '@utils/content';
import OpexTable from '@assets/OpexTable.astro';
import FindingsUI from '@assets/FindingsUI.astro';
import ConsumptionUI from '@assets/ConsumptionUI.astro';
import heroVideoAv1 from '@assets/aerial.av1.mp4';
import heroVideoWebm from '@assets/aerial.webm';
import heroPoster from '@assets/poster.jpg';

const posts = await getCollection('news', filterDrafts);

const caseExamplePosts = posts
  .filter((post) => post.data.category === 'case-study' && post.data.callout !== undefined)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout title={config.title} ogTitle={config.ogtitle} description={config.description}>
  <section class="relative bg-neutral-900 dark:bg-neutral-950">
    <div class="absolute inset-0 z-0 mask-linear-315 mask-linear-from-0%">
      <video
        aria-hidden="true"
        playsinline
        autoplay
        muted
        loop
        class="absolute inset-0 size-full object-cover"
        poster={heroPoster.src}
      >
        <source src={heroVideoAv1} type="video/mp4" />
        <source src={heroVideoWebm} type="video/webm" />
      </video>
    </div>
    <div class="relative">
      <SiteHeader
        headerClass="bg-transparent dark:bg-transparent text-neutral-50 dark:text-neutral-50"
        itemClass="hover:bg-current/10 active:bg-current/10 text-shadow-sm"
      />
      <div class="container py-28 lg:py-56">
        <div class="-mt-4 drop-shadow-[0_0_24px] drop-shadow-black/75">
          <h1 class="mb-6 max-w-[25ch] font-serif text-4xl text-neutral-50 lg:text-6xl xl:text-7xl">
            Turn building data into investment-grade asset intelligence
          </h1>
          <p class="mb-8 max-w-prose leading-normal text-balance text-neutral-50 lg:text-lg">
            Clouder’s asset intelligence unlocks hidden value in commercial real estate portfolios
            with industry specific AI agents.
          </p>
          <a
            href={paths.contact.href}
            class="inline-flex h-10 cursor-pointer items-center justify-center rounded bg-neutral-50 px-4 text-center text-sm text-nowrap text-neutral-950 shadow-xs transition select-none hover:bg-neutral-300 active:bg-neutral-300"
          >
            Get started today
          </a>
        </div>
      </div>
    </div>
  </section>
  <section class="py-16 lg:py-32">
    <div class="container">
      <h2 class="font-serif text-3xl text-neutral-950 lg:text-5xl dark:text-neutral-50">
        AI Platform with investment grade data:
        <span class="opacity-50"
          >Live, structured data from every building system that is always current, always
          audit-ready.</span
        >
      </h2>
      <div class="h-8 lg:h-16"></div>
      <div class="grid gap-8 lg:grid-cols-3">
        <div class="space-y-1">
          <div
            class="mb-4 w-fit rounded-lg bg-neutral-950 p-4 text-neutral-50 dark:bg-neutral-50 dark:text-neutral-950"
          >
            <TargetIcon size={20} />
          </div>
          <p class="text-lg font-medium text-neutral-950 dark:text-neutral-50">
            Investment-grade data
          </p>
          <p class="text-balance text-neutral-700 dark:text-neutral-300">
            Live, structured data from every building system that is always current, always
            audit-ready.
          </p>
        </div>
        <div class="space-y-1">
          <div
            class="mb-4 w-fit rounded-lg bg-neutral-950 p-4 text-neutral-50 dark:bg-neutral-50 dark:text-neutral-950"
          >
            <ZapIcon size={20} />
          </div>
          <p class="text-lg font-medium text-neutral-950 dark:text-neutral-50">Agentic AI</p>
          <p class="text-balance text-neutral-700 dark:text-neutral-300">
            Industry-specific agents trained on real estate operations, not general-purpose tools
            repurposed for the job.
          </p>
        </div>
        <div class="space-y-1">
          <div
            class="mb-4 w-fit rounded-lg bg-neutral-950 p-4 text-neutral-50 dark:bg-neutral-50 dark:text-neutral-950"
          >
            <ChartColumnIcon size={20} />
          </div>
          <p class="text-lg font-medium text-neutral-950 dark:text-neutral-50">
            Value & performance
          </p>
          <p class="text-balance text-neutral-700 dark:text-neutral-300">
            NOI improvement that is visible, tracked, and defensible, measured result against a
            verified baseline.
          </p>
        </div>
      </div>
    </div>
    <div class="h-16 lg:h-32"></div>
    <div class="container">
      <LogoRow />
    </div>
  </section>
  <Divider />
  <section class="py-16 lg:py-32">
    <div class="container">
      <p class="mb-4 text-xs font-medium tracking-wider text-neutral-500 uppercase lg:mb-6">
        Our solutions
      </p>
      <h2
        class="mb-4 font-serif text-3xl text-neutral-950 lg:mb-6 lg:text-5xl dark:text-neutral-50"
      >
        Your portfolio<br class="hidden lg:block" /> constantly optimized
      </h2>
      <div class="flex flex-col items-start gap-6 lg:flex-row">
        <p class="text-balance">
          We connect directly to your building systems – not through cloud APIs – to provide
          investment-grade data. Every building we operate gets smarter over time creating
          compounding value.
        </p>
        <a
          href={paths.solutions.href}
          class="inline-flex h-10 cursor-pointer items-center justify-center rounded bg-neutral-950 px-4 text-center text-sm text-nowrap text-neutral-50 transition select-none hover:bg-neutral-700 active:bg-neutral-700 dark:bg-neutral-50 dark:text-neutral-950 dark:hover:bg-neutral-300 dark:active:bg-neutral-300"
        >
          Learn more
        </a>
      </div>
      <div class="h-8 lg:h-16"></div>
      <div class="grid gap-x-4 gap-y-8 lg:grid-cols-3">
        <div>
          <div
            class="relative aspect-square overflow-hidden bg-linear-to-b from-neutral-200 to-neutral-300 lg:aspect-3/4 dark:from-neutral-700 dark:to-neutral-800"
          >
            <div
              class="absolute inset-0 flex scale-85 flex-col items-center justify-center select-none xl:scale-100"
            >
              <ConsumptionUI />
            </div>
          </div>
          <h4 class="mt-4 mb-2 text-lg font-medium text-neutral-950 dark:text-neutral-50">
            Real-time reporting
          </h4>
          <p class="text-balance text-neutral-700 dark:text-neutral-300">
            Energy agents create your energy and performance reports automatically from live meter
            data, always current, always accurate.
          </p>
        </div>
        <div>
          <div
            class="relative aspect-square overflow-hidden bg-linear-to-b from-neutral-200 to-neutral-300 lg:aspect-3/4 dark:from-neutral-700 dark:to-neutral-800"
          >
            <div
              class="group absolute inset-0 flex scale-85 flex-col items-center justify-center gap-3 select-none sm:left-0 xl:scale-100"
            >
              <FindingsUI title="Consumption levels normalised after scheduling fix" status="ok" />
              <div
                class="-z-1 -mt-21.5 scale-95 transition-all duration-300 group-hover:mt-0 group-hover:scale-100 group-hover:opacity-100 group-active:mt-0 group-active:scale-100 group-active:opacity-100"
              >
                <FindingsUI title="Suboptimal conditions for tenants in Zone A" status="warning" />
              </div>
              <div
                class="-z-2 -mt-17.75 scale-90 transition-all duration-300 group-hover:mt-0 group-hover:scale-100 group-hover:opacity-100 group-active:mt-0 group-active:scale-100 group-active:opacity-100"
              >
                <FindingsUI title="Air handling unit 306 bus fault" status="error" />
              </div>
            </div>
          </div>
          <h4 class="mt-4 mb-2 text-lg font-medium text-neutral-950 dark:text-neutral-50">
            Autonomous fault detection
          </h4>
          <p class="text-balance text-neutral-700 dark:text-neutral-300">
            Our platform assesses the building's performance constantly against its target behavior
            and alerts maintenance the moment something needs fixing.
          </p>
        </div>
        <div>
          <div
            class="relative aspect-square overflow-hidden bg-linear-to-b from-neutral-200 to-neutral-300 lg:aspect-3/4 dark:from-neutral-700 dark:to-neutral-800"
          >
            <div
              class="group absolute inset-0 flex scale-85 flex-col items-center justify-center select-none xl:scale-100"
            >
              <div
                class="relative rounded-3xl bg-neutral-100 p-4 shadow-xl shadow-black/5 dark:bg-neutral-700"
              >
                <svg
                  width="64"
                  height="64"
                  viewBox="0 0 64 64"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                  class="shrink-0"
                >
                  <rect width="64" height="64" rx="14" fill="black"></rect>
                  <path
                    fill-rule="evenodd"
                    clip-rule="evenodd"
                    d="M16 33C16 22.5066 24.5066 14 35 14H46V20H35C27.8203 20 22 25.8203 22 33C22 40.1797 27.8203 46 35 46H46V52H35C24.5066 52 16 43.4934 16 33Z"
                    fill="white"></path>
                </svg>
                <div
                  class="absolute top-2 right-2 flex size-5 scale-0 items-center justify-center rounded-full bg-red-500 opacity-0 transition duration-300 group-hover:scale-100 group-hover:opacity-100 group-active:scale-100 group-active:opacity-100"
                >
                  <span class="text-[10px] leading-none font-medium text-white">1</span>
                </div>
              </div>
            </div>
          </div>
          <h4 class="mt-4 mb-2 text-lg font-medium text-neutral-950 dark:text-neutral-50">
            Commissioning verification
          </h4>
          <p class="text-balance text-neutral-700 dark:text-neutral-300">
            In renovations and new developments, we give you real-time confirmation that the
            building is being commissioned correctly and runs efficiently from day one.
          </p>
        </div>
      </div>
    </div>
    <div class="h-16 lg:h-32"></div>
    <div class="container">
      <div class="grid gap-x-4 gap-y-8 lg:grid-cols-2 lg:gap-x-8">
        <div>
          <h2
            class="mb-4 font-serif text-3xl text-neutral-950 lg:mb-6 lg:text-5xl dark:text-neutral-50"
          >
            What asset intelligence does to your portfolio
          </h2>
          <p class="mb-4 text-balance">
            Commercial real estate portfolios carry significant unrealised value. Not from market
            movements, but from operational friction that has never been measured.
          </p>
          <p class="mb-6 font-medium text-neutral-950 dark:text-neutral-50">
            We make it visible, then we eliminate it.
          </p>
          <a
            href={paths.contact.href}
            class="inline-flex h-10 cursor-pointer items-center justify-center rounded bg-neutral-950 px-4 text-center text-sm text-nowrap text-neutral-50 transition select-none hover:bg-neutral-700 active:bg-neutral-700 dark:bg-neutral-50 dark:text-neutral-950 dark:hover:bg-neutral-300 dark:active:bg-neutral-300"
          >
            Get started today
          </a>
        </div>
        <div
          class="bg-linear-to-b from-neutral-200 to-neutral-300 p-8 pb-6 lg:p-12 lg:pb-8 dark:from-neutral-700 dark:to-neutral-800"
        >
          <OpexTable />
        </div>
      </div>
    </div>
  </section>
  <Divider />
  <section class="py-16 lg:py-32">
    <div class="container">
      <p class="mb-4 text-xs font-medium tracking-wider text-neutral-500 uppercase lg:mb-6">
        Customer success
      </p>
      <h2 class="font-serif text-3xl text-neutral-950 lg:text-5xl dark:text-neutral-50">
        Trusted by industry leaders
      </h2>
      <div class="h-8 lg:h-16"></div>
      <div class="mb-4 space-y-4">
        {caseExamplePosts.map((post) => <QuotePost post={post} />)}
      </div>
    </div>
  </section>
  <Divider />
  <section class="py-16 lg:py-32">
    <div class="container">
      <h2 class="font-serif text-3xl text-neutral-950 lg:text-5xl dark:text-neutral-50">
        Simple engagement. <span class="opacity-50 lg:block">Fast time to value.</span>
      </h2>
      <div class="h-8 lg:h-16"></div>
      <div class="grid gap-x-4 gap-y-12 lg:grid-cols-3 lg:gap-x-8">
        <div class="space-y-2">
          <p class="text-sm font-[450] text-neutral-500">01</p>
          <hr class="mb-4 border-current/10" />
          <h4 class="text-lg font-medium text-neutral-950 dark:text-neutral-50">Assesment</h4>
          <p class="text-balance text-neutral-700 dark:text-neutral-300">
            We assess your assets and quantify exactly what is being left on the table.
          </p>
        </div>
        <div class="space-y-2">
          <p class="text-sm font-[450] text-neutral-500">02</p>
          <hr class="mb-4 border-current/10" />
          <h4 class="text-lg font-medium text-neutral-950 dark:text-neutral-50">Proof of value</h4>
          <p class="text-balance text-neutral-700 dark:text-neutral-300">
            We connect the data, close the gaps, and deliver measurable NOI improvement on a single
            asset.
          </p>
        </div>
        <div class="space-y-2">
          <p class="text-sm font-[450] text-neutral-500">03</p>
          <hr class="mb-4 border-current/10" />
          <h4 class="text-lg font-medium text-neutral-950 dark:text-neutral-50">Scaling</h4>
          <p class="text-balance text-neutral-700 dark:text-neutral-300">
            AI agents, automatic reporting, and continuous optimisation from day one.
          </p>
        </div>
        <div class="space-y-2">
          <div class="flex items-center gap-1.5">
            <RepeatIcon size={16} class="shrink-0" />
            <h4 class="text-lg font-medium text-neutral-950 dark:text-neutral-50">Roll it out</h4>
          </div>
          <p class="text-balance text-neutral-700 dark:text-neutral-300">
            The same loop across your assets with compounding results.
          </p>
        </div>
        <div class="self-end">
          <a
            href={paths.contact.href}
            class="inline-flex h-10 cursor-pointer items-center justify-center rounded bg-neutral-950 px-4 text-center text-sm text-nowrap text-neutral-50 transition select-none hover:bg-neutral-700 active:bg-neutral-700 dark:bg-neutral-50 dark:text-neutral-950 dark:hover:bg-neutral-300 dark:active:bg-neutral-300"
          >
            Get in touch
          </a>
        </div>
      </div>
    </div>
  </section>
  <SiteFooter />
</BaseLayout>
