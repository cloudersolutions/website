---
import { getCollection } from 'astro:content';
import ChevronRightIcon from 'lucide-astro/ChevronRight';
import MainLayout from '@layouts/MainLayout.astro';
import CaseExamplePost from '@components/CaseExamplePost.astro';
import ConsumptionUI from '@components/ConsumptionUI.astro';
import GaugeScoreUI from '@components/GaugeScoreUI.astro';
import FindingUI from '@components/FindingUI.astro';
import GetStarted from '@components/GetStarted.astro';
import HistoryUI from '@components/HistoryUI.astro';
import LogoRow from '@components/LogoRow.astro';
import Quote from '@components/Quote.astro';
import SustainabilityUI from '@components/SustainabilityUI2.astro';
import config from '@data/config.yml';
import { paths } from '@data/paths';
import { filterDrafts } from '@utils/content';
import heroVideoWebm from '@assets/hero.webm';
import heroVideoAv1 from '@assets/hero.av1.mp4';

const posts = await getCollection('news', filterDrafts);

const caseExamplePosts = posts
  .filter((post) => post.data.category === 'case-example')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<MainLayout
  title={config.title}
  ogTitle={config.ogtitle}
  description={config.description}
  headerClass="bg-black dark:bg-black text-neutral-50 dark:text-neutral-50"
  headerItemClass="hover:bg-current/10 active:bg-current/10"
>
  <section class="relative overflow-clip border-b border-current/10 bg-black">
    <div class="relative z-1 container">
      <div
        class="bg-linear-to-r from-black from-50% to-transparent pt-20 text-center sm:pt-24 md:pt-28 lg:max-w-150 lg:pt-40 lg:pb-48 lg:text-left xl:pt-48 xl:pb-56"
      >
        <h1 class="mb-8 text-4xl font-semibold text-white md:text-5xl xl:text-6xl">
          Turn building data into investment-grade asset intelligence
        </h1>
        <p class="mb-10 text-xl text-neutral-200">
          Clouder’s asset intelligence unlocks hidden value in commercial real estate portfolios
          with industry specific AI agents.
        </p>
        <a
          href={paths.contact.href}
          class="inline-flex h-10 cursor-pointer items-center justify-center rounded bg-neutral-200 px-4 text-center text-sm font-medium text-nowrap text-neutral-950 shadow-xs transition select-none hover:bg-white active:bg-white"
        >
          Get started today
        </a>
      </div>
    </div>
    <div
      class="relative z-0 aspect-square size-full mask-t-from-75% mask-r-from-75% mask-l-from-75% sm:aspect-video lg:absolute lg:inset-0 lg:left-1/4 lg:container"
    >
      <video
        aria-hidden="true"
        playsinline
        autoplay
        muted
        loop
        class="absolute inset-0 size-full object-cover"
      >
        <source src={heroVideoAv1} type="video/mp4; codecs=av01" />
        <source src={heroVideoWebm} type="video/webm; codecs=vp9" />
      </video>
    </div>
  </section>
  <section class="py-16 sm:py-20 md:py-24 lg:py-32">
    <div class="container">
      <div class="pb-8">
        <p class="mb-6 text-center text-lg font-semibold">Trusted by</p>
        <LogoRow />
      </div>
      <div class="my-12 sm:my-16 md:my-20 lg:my-24">
        <h2 class="mb-6 text-3xl font-semibold text-neutral-950 md:text-4xl dark:text-neutral-50">
          Your portfolio constantly optimized
        </h2>
        <div class="grid gap-6 lg:grid-cols-3 lg:gap-12">
          <div class="col-span-2">
            <p class="mb-4">
              The critical difference: we connect directly to your building systems — not through
              cloud APIs. This means we don't just read data. We act on it, in real time, and learn
              from the result. Every building we operate gets smarter over time. Every new asset
              benefits from what we have already learned.
            </p>
            <p class="font-medium text-neutral-950 dark:text-neutral-50">
              You keep full visibility and control. We handle everything in between.
            </p>
          </div>
          <div class="text-right">
            <a
              href={paths.contact.href}
              class="inline-flex h-10 cursor-pointer items-center justify-center gap-1 rounded bg-neutral-800 px-4 text-center text-sm font-medium text-nowrap text-neutral-50 transition select-none hover:bg-neutral-950 active:bg-neutral-950 dark:bg-neutral-200 dark:text-neutral-950 dark:hover:bg-white dark:active:bg-white"
            >
              Book a free consultation
            </a>
          </div>
        </div>
        <div class="mt-12 grid gap-6 lg:grid-cols-3">
          <div>
            <div
              class="relative aspect-square overflow-hidden bg-neutral-200 lg:aspect-3/4 dark:bg-neutral-800"
            >
              <div
                class="absolute inset-0 flex scale-85 flex-col items-center justify-center xl:scale-100"
              >
                <ConsumptionUI />
              </div>
            </div>
            <p class="mt-4 mb-1 font-semibold text-neutral-950 dark:text-neutral-50">
              Real-time reporting
            </p>
            <p>
              Energy agents create your energy and performance reports automatically from live meter
              data, always current, always accurate.
            </p>
          </div>

          <div>
            <div
              class="relative aspect-square overflow-hidden bg-neutral-200 lg:aspect-3/4 dark:bg-neutral-800"
            >
              <div
                class="absolute inset-0 flex scale-85 flex-col items-center justify-center gap-3 sm:left-0 xl:scale-100"
              >
                <FindingUI
                  title="Significant overconsumption in heating and cooling"
                  timeAgo="5 hours ago"
                  iconClass="text-red-600 dark:text-red-400"
                />
                <FindingUI
                  title="Suboptimal conditions for tenants in Zone A"
                  timeAgo="1 day ago"
                  iconClass="text-yellow-600 dark:text-yellow-400"
                />
              </div>
            </div>
            <p class="mt-4 mb-1 font-semibold text-neutral-950 dark:text-neutral-50">
              Autonomous fault detection
            </p>
            <p>
              Our platform assesses the building’s performance constantly against its target
              behavior and alerts maintenance the moment something needs fixing before it becomes a
              complaint. Cutting energy waste and costs.
            </p>
          </div>
          <div>
            <div
              class="flex aspect-square flex-col items-center justify-center overflow-hidden bg-neutral-200 lg:aspect-3/4 dark:bg-neutral-800"
            >
              <div
                class="relative rounded-3xl bg-neutral-100 p-4 shadow-xl shadow-black/5 dark:bg-neutral-700"
              >
                <svg
                  width="64"
                  height="64"
                  viewBox="0 0 64 64"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                  class="shrink-0"
                >
                  <rect width="64" height="64" rx="14" fill="black"></rect>
                  <path
                    fill-rule="evenodd"
                    clip-rule="evenodd"
                    d="M16 33C16 22.5066 24.5066 14 35 14H46V20H35C27.8203 20 22 25.8203 22 33C22 40.1797 27.8203 46 35 46H46V52H35C24.5066 52 16 43.4934 16 33Z"
                    fill="white"></path>
                </svg>
                <div
                  class="absolute top-2 right-2 flex size-5 items-center justify-center rounded-full bg-red-500"
                >
                  <span class="text-[10px] leading-none font-medium text-white">1</span>
                </div>
              </div>
            </div>
            <p class="mt-4 mb-1 font-semibold text-neutral-950 dark:text-neutral-50">
              Commissioning verification
            </p>
            <p>
              In renovations and new developments, we give you real-time confirmation that the
              building is being commissioned correctly and it runs efficiently from day one.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <section class="border-t border-current/10 py-16 sm:py-20 md:py-24 lg:py-32">
    <div class="container">
      <div class="grid gap-6 lg:grid-cols-2 lg:gap-18">
        <div>
          <h2 class="mb-6 text-3xl font-semibold text-neutral-950 md:text-4xl dark:text-neutral-50">
            What asset intelligence does to your portfolio
          </h2>
          <p class="mb-4">
            Commercial real estate portfolios carry significant unrealised value. Not from market
            movements, but from operational friction that has never been measured. Research from
            McKinsey, JLL, and Morgan Stanley puts the recoverable opportunity at 10–30% of total
            opex.
          </p>
          <p class="font-medium text-neutral-950 dark:text-neutral-50">
            We make it visible, then we eliminate it.
          </p>
        </div>
        <div>
          <table class="w-full text-left text-sm">
            <thead>
              <tr>
                <th class="py-2.5 font-semibold text-neutral-500">Source</th>
                <th class="py-2.5 text-right font-semibold text-neutral-500">Annual impact</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="border-t border-current/10 py-2.5">Energy opex reduction (20%)</td>
                <td class="border-t border-current/10 py-2.5 text-right">+ €1,200,000 NOI</td>
              </tr>
              <tr>
                <td class="border-t border-current/10 py-2.5">Maintenance cost reduction (20%)</td>
                <td class="border-t border-current/10 py-2.5 text-right">+ €900,000 NOI</td>
              </tr>
              <tr>
                <td class="border-t border-current/10 py-2.5">Admin & back-office efficiency</td>
                <td class="border-t border-current/10 py-2.5 text-right">+ €170,000 NOI</td>
              </tr>
              <tr>
                <td class="border-t border-current/10 py-2.5">Rent premium from ESG positioning</td>
                <td class="border-t border-current/10 py-2.5 text-right">+ €600,000 NOI</td>
              </tr>
              <tr>
                <td class="border-t border-current/10 py-2.5 font-semibold"
                  >Total NOI improvement</td
                >
                <td class="border-t border-current/10 py-2.5 text-right font-semibold"
                  >+ €2,870,000/yr</td
                >
              </tr>
              <tr>
                <td class="border-t border-current/10 py-2.5 font-semibold"
                  >Asset value uplift at 6% cap rate</td
                >
                <td class="border-t border-current/10 py-2.5 text-right font-semibold"
                  >+ €47,800,000 GAV</td
                >
              </tr>
            </tbody>
          </table>
          <p class="mt-2 text-xs text-neutral-500 italic">
            Benchmarks applied on a €500M portfolio at 6% cap rate
          </p>
        </div>
      </div>
      <div class="mt-24 grid grid-cols-1 gap-6 lg:grid-cols-2 lg:gap-18">
        <Quote
          quote="It’s our priority to stay at the forefront of sustainable construction. Partnering with Clouder in this project ensures we remain agile, innovative, and prepared to meet the growing demand from environmentally conscious owners and occupiers."
          citeName="Mikko Sirviö"
          citeTitle="Director of Commercial Construction"
          citeCompany="Varte"
        />
        <Quote
          quote="We had two machines going on 16 hours per day and now we’re able to save so much energy being able to control them in real time by the usage of the space. I bet our energy savings are more than 50% with this."
          citeName="Jani Pulkkinen"
          citeTitle="Construction Manager"
          citeCompany="Conficap"
        />
      </div>
    </div>
  </section>
  <section class="border-t border-current/10 py-16 sm:py-20 md:py-24 lg:py-32">
    <div class="container">
      <div class="my-6 grid gap-6 md:gap-9 lg:grid-cols-3 lg:gap-12">
        <h2
          class="col-span-full text-3xl font-semibold text-neutral-950 md:text-4xl dark:text-neutral-50"
        >
          Simple engagement. Fast time to value.
        </h2>
        <div>
          <p class="mb-1 font-mono text-xs text-neutral-500">01</p>
          <p class="font-semibold">Assesment</p>
          <p>We assess your assets and quantify exactly what is being left on the table.</p>
        </div>
        <div>
          <p class="mb-1 font-mono text-xs text-neutral-500">02</p>
          <p class="font-semibold">Proof of value</p>
          <p>
            We connect the data, close the gaps, and deliver measurable NOI improvement on a single
            asset.
          </p>
        </div>
        <div>
          <p class="mb-1 font-mono text-xs text-neutral-500">03</p>
          <p class="font-semibold">Scaling</p>
          <p>AI agents, automatic reporting, and continuous optimisation from day one.</p>
        </div>
        <div class="col-span-full flex flex-wrap justify-between gap-4">
          <p class="col-span-2">
            <strong>Roll it out:</strong> The same loop across your assets with compounding results.
          </p>
          <div class="text-right">
            <a
              href={paths.contact.href}
              class="inline-flex h-10 cursor-pointer items-center justify-center gap-1 rounded bg-neutral-800 px-4 text-center text-sm font-medium text-nowrap text-neutral-50 transition select-none hover:bg-neutral-950 active:bg-neutral-950 dark:bg-neutral-200 dark:text-neutral-950 dark:hover:bg-white dark:active:bg-white"
            >
              Book a free consultation
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
  {
    caseExamplePosts.length > 0 && (
      <section class="container pb-16 sm:pb-20 md:pb-24 lg:pb-32">
        <div class="mb-8 flex items-center justify-between gap-4 text-center md:mb-12">
          <h2 class="text-2xl font-semibold text-neutral-950 md:text-3xl dark:text-neutral-50">
            Results from our customers
          </h2>
          <a
            href={`${paths.news.href}/case-example`}
            class="group inline-flex items-center gap-0.5 text-neutral-500 transition hover:text-current active:text-current"
          >
            More case examples
            <ChevronRightIcon
              class="mt-0.5 transition group-hover:translate-x-0.5 group-hover:text-current group-active:text-current"
              size={16}
            />
          </a>
        </div>
        <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
          {caseExamplePosts.map((post) => (
            <CaseExamplePost post={post} />
          ))}
        </div>
      </section>
    )
  }
</MainLayout>
