---
import { Image } from 'astro:assets';

import MainLayout from '@layouts/MainLayout.astro';
import ecImage from '@assets/ec-6-2.png';

const title = 'Edge Connector 6-2';
---

<MainLayout title={title}>
  <div class="container-narrow py-16 lg:py-32">
    <h1 class="text-center font-serif text-4xl text-neutral-950 lg:text-5xl dark:text-neutral-50">
      {title}
    </h1>
    <Image
      src={ecImage}
      alt={title}
      class="bg-transparent text-transparent"
      width={960}
      layout="constrained"
    />
  </div>
</MainLayout>
