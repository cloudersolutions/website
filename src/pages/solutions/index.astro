---
import BlocksIcon from 'lucide-astro/Blocks';
import ChevronsLeftRightEllipsisIcon from 'lucide-astro/CodeSquare';
import DatabaseIcon from 'lucide-astro/Database';
import LaptopIcon from 'lucide-astro/Laptop';
import OcatagonAlertIcon from 'lucide-astro/OctagonAlert';
import SettingsIcon from 'lucide-astro/Settings';
import ShieldCheckIcon from 'lucide-astro/ShieldCheck';
import SparklesIcon from 'lucide-astro/Sparkles';
import WrenchIcon from 'lucide-astro/Wrench';
import MainLayout from '@layouts/MainLayout.astro';
import Divider from '@components/Divider.astro';
import { formatCurrency } from '@utils/format';
import { paths } from '@data/paths';
import PerformanceUI from '@assets/PerformanceUI.astro';

const title = 'Product';
const description = 'Clouder unlcoks the hidden value.';

const features = [
  {
    icon: BlocksIcon,
    title: 'Integration platform',
    content: [
      'Clouder performs integrations directly on-site, meaning we are not dependent on existing cabling, API’s, or BMS programming.',
      'On-site data processing ensures accurate, comprehensive, and context-rich data that is immediately ready for AI and ML applications.'
    ]
  },
  {
    icon: LaptopIcon,
    title: 'Clouder Dashboard',
    content: [
      'A centralized overview of your entire property with access to high-level insights and granular details.',
      'Track energy consumption and distribution with precision. Drill down to device and data point level when needed.  Export data effortlessly for reporting.'
    ]
  },
  {
    icon: SparklesIcon,
    title: 'Clouder agents',
    content: [
      'Multiple Clouder agents analyze your assets to give you valuable insights on their performance.',
      'The insights and data produced by agents is also available through MCP for all internal use cases.'
    ]
  },
  {
    icon: DatabaseIcon,
    title: 'Data storage',
    content: [
      'Cloud-based data storage accessible via Clouder Dashboard, API, and MCP. No more relying on benchmarks or estimates.',
      'Our five-year data retention policy gives you full ownership and control of your data.'
    ]
  },
  {
    icon: ChevronsLeftRightEllipsisIcon,
    title: 'Real-time API',
    content: [
      'Access all building data through our real-time API.',
      'Ideal for smart office apps, property management software, and other third-party integrations.'
    ]
  },
  {
    icon: OcatagonAlertIcon,
    title: 'Fault detection & diagnostics',
    content: [
      'Quickly identify and diagnose faults, problems, and conflicts in your building automation system.',
      'Receive targeted recommendations and clear guidance for resolving identified issues.'
    ]
  },
  {
    icon: SettingsIcon,
    title: 'Device control',
    content: [
      'Control all systems and devices in your building without disrupting the existing building automation system.',
      'Use sophisticated, event-based rules to control devices to further reduce energy consumption.'
    ]
  },
  {
    icon: ShieldCheckIcon,
    title: 'Security built-in',
    content: [
      'Fine-grained data access rules, accurate audit trail, end-to-end encryption, and secure cloud storage of your building data.',
      'Robust security in building automation with centralized password management. No more default passwords known by everyone.'
    ]
  },
  {
    icon: WrenchIcon,
    title: 'Custom integrations',
    content: [
      'We can offer tailored solutions and consulting services to address your specific needs, from advanced system integrations to personalized building performance strategies.'
    ],
    showCta: true
  }
];

const faq = [
  {
    question: 'Where can Clouder be installed?',
    answer:
      'Clouder can be installed in all types of properties, both existing and new construction. Pilot buildings typically go live in two weeks. Portfolio rollouts then follow a repeatable playbook. Deployments are capex-light, minimally disruptive to tenants, and deliver value from day one.'
  },
  {
    question: 'How quickly can we implement Clouder across a portfolio?',
    answer:
      'Pilot buildings typically go live in two weeks. Portfolio rollouts then follow a repeatable playbook. Deployments are capex-light, minimally disruptive to tenants, and deliver value from day one.'
  },
  {
    question: 'Is Clouder compatible with our existing systems and vendors?',
    answer:
      'Yes. Clouder integrates with all major building protocols, for example BACnet and Modbus. Owners can retain their existing systems while unifying data into a clean, actionable layer.'
  },
  {
    question: 'What about cybersecurity and data ownership?',
    answer:
      'You retain full ownership and control of your data. Clouder applies end-to-end encryption, accurate audit trails, and secure cloud connections.'
  },
  {
    question: 'What are the annual costs? Are there any license fees?',
    answer:
      "Our pricing structure consists of a setup fee and a monthly subscription fee. The fees are determined by building size, complexity, data volume, selected features, and service scope. We don't charge any additional license fees for any of our plans."
  },
  {
    question: 'Which asset classes benefit most from Clouder?',
    answer:
      'Clouder scales across residential, office, logistics and mixed-use assets. Any building type with siloed systems benefits from reduced operating costs, improved sustainability metrics and higher valuations.'
  },
  {
    question: 'How does Clouder work with our existing ESG reporting software?',
    answer:
      'Clouder supplies the clean, unified data that ESG software depends on. This eliminates manual data collection, reduces errors, and ensures that operational efficiency gains show up clearly in compliance and valuation metrics. You can keep using your existing ESG-software. Clouder will serve clean data to that platform through the API.'
  },
  {
    question: 'How does Clouder help with EU Taxonomy and CSRD compliance?',
    answer:
      'Clouder integrates energy, water, indoor climate and automation data into one standardised layer. This makes reporting under EU Taxonomy and CSRD accurate and traceable.'
  },
  {
    question: 'Can Clouder improve our GRESB score?',
    answer:
      'Yes. By increasing data coverage and reducing consumption, Clouder strengthens the Management and Performance components of GRESB. Better metering, benchmarking and fault detection all contribute to higher scores and more attractive valuations.'
  }
];
---

<MainLayout title={title} description={description}>
  <section>
    <div class="pt-16 pb-8 lg:pt-32 lg:pb-16">
      <div class="container">
        <h1
          class="mb-4 font-serif text-4xl text-neutral-950 lg:mb-6 lg:text-5xl xl:text-6xl dark:text-neutral-50"
        >
          The new standard for<br class="hidden lg:block" /> property performance
        </h1>
        <p class="text-blance lg:text-lg xl:text-xl">{description}</p>
      </div>
    </div>
    <div class="pb-16 lg:pb-32">
      <div
        class="container bg-linear-to-b from-neutral-200 to-neutral-300 p-8 lg:p-16 dark:from-neutral-700 dark:to-neutral-800"
      >
        <PerformanceUI />
      </div>
    </div>
  </section>
  <Divider />
  <section>
    <div class="pt-16 pb-8 lg:pt-32 lg:pb-16">
      <div class="container">
        <p class="mb-4 text-xs font-medium tracking-wider text-neutral-500 uppercase lg:mb-6">
          How it works
        </p>
        <h2 class="font-serif text-3xl text-neutral-950 lg:text-4xl dark:text-neutral-50">
          Turn building data<br class="hidden lg:block" /> into operational value
        </h2>
      </div>
    </div>
    <div class="pb-16 lg:pb-32">
      <div class="container">
        <div class="grid gap-x-4 gap-y-8 lg:grid-cols-3">
          <div>
            <div
              class="relative aspect-square overflow-hidden bg-linear-to-b from-neutral-200 to-neutral-300 lg:aspect-3/4 dark:from-neutral-700 dark:to-neutral-800"
            >
              <div
                class="absolute inset-0 flex scale-85 flex-col items-center justify-center xl:scale-100"
              >
              </div>
            </div>
            <h4 class="mt-4 mb-1 font-medium text-neutral-950 dark:text-neutral-50">Integration</h4>
            <p class="mb-4 pr-4 text-balance text-neutral-700 dark:text-neutral-300">
              Clouder connects directly into your building systems. On-site data normalization is
              done before securely transmitting the data into the cloud, to ensure your data is
              always accurate and accessible in real time.
            </p>
            <p class="text-sm text-neutral-500">
              Setup fee: {formatCurrency(500)}<br />
              Monthly fee: {formatCurrency(1000)} per building
            </p>
          </div>
          <div>
            <div
              class="relative aspect-square overflow-hidden bg-linear-to-b from-neutral-200 to-neutral-300 lg:aspect-3/4 dark:from-neutral-700 dark:to-neutral-800"
            >
              <div
                class="absolute inset-0 flex scale-85 flex-col items-center justify-center xl:scale-100"
              >
              </div>
            </div>
            <h4 class="mt-4 mb-1 font-medium text-neutral-950 dark:text-neutral-50">
              Agentic analysis
            </h4>
            <p class="mb-4 pr-4 text-balance text-neutral-700 dark:text-neutral-300">
              Multiple Clouder agents analyze your assets to uncover hidden value and optimize
              performance. Automated energy and performance reports are generated from live data, so
              you always have accurate, up-to-date information.
            </p>
            <p class="text-sm text-neutral-500">
              Setup fee: {formatCurrency(2000)}<br />
              Monthly fee: {formatCurrency(3000)} per building
            </p>
          </div>
          <div>
            <div
              class="relative aspect-square overflow-hidden bg-linear-to-b from-neutral-200 to-neutral-300 lg:aspect-3/4 dark:from-neutral-700 dark:to-neutral-800"
            >
              <div
                class="absolute inset-0 flex scale-85 flex-col items-center justify-center xl:scale-100"
              >
              </div>
            </div>
            <h4 class="mt-4 mb-1 font-medium text-neutral-950 dark:text-neutral-50">
              Monthly check-ins
            </h4>
            <p class="pr-4 text-balance text-neutral-700 dark:text-neutral-300">
              We’re committed to your success, which is why we provide monthly check-ins to help you
              get the most out of Clouder. Your building data always remains yours—full access and
              ownership are guaranteed.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <Divider />
  <section>
    <div class="pt-16 pb-8 lg:pt-32 lg:pb-16">
      <div class="container">
        <p class="mb-4 text-xs font-medium tracking-wider text-neutral-500 uppercase lg:mb-6">
          Features
        </p>
        <h2 class="font-serif text-3xl text-neutral-950 lg:text-4xl dark:text-neutral-50">
          The platform powering<br class="hidden lg:block" /> building intelligence
        </h2>
      </div>
    </div>
    <div class="pb-16 lg:pb-32">
      <div class="container">
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3 lg:grid-rows-3">
          {
            features.map(({ icon: Icon, title, content, showCta }) => (
              <div class="space-y-2 rounded-lg border border-neutral-200 p-6 lg:pb-16 dark:border-neutral-800">
                <Icon size={20} class="mb-3 shrink-0 text-neutral-500" />
                <h4 class="font-medium text-neutral-950 dark:text-neutral-50">{title}</h4>

                {content.map((p) => (
                  <p class="text-neutral-700 dark:text-neutral-300">{p}</p>
                ))}
                {showCta && (
                  <a
                    href={paths.contact.href}
                    class="mt-2 inline-flex h-9 cursor-pointer items-center justify-center rounded bg-neutral-950 px-3.5 text-center text-sm text-nowrap text-neutral-50 transition select-none hover:bg-neutral-700 active:bg-neutral-700 dark:bg-neutral-50 dark:text-neutral-950 dark:hover:bg-neutral-300 dark:active:bg-neutral-300"
                  >
                    Let’s talk
                  </a>
                )}
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>
  <Divider />
  <section>
    <div class="py-16 lg:py-32">
      <div class="container">
        <div class="grid grid-cols-1 items-start gap-8 lg:grid-cols-3">
          <div>
            <h2
              class="mb-4 font-serif text-3xl text-neutral-950 lg:mb-6 lg:text-4xl dark:text-neutral-50"
            >
              FAQ
            </h2>
            <button
              id="toggle-button"
              class="inline-flex h-9 cursor-pointer items-center justify-center rounded bg-neutral-950 px-3.5 text-center text-sm text-nowrap text-neutral-50 transition select-none hover:bg-neutral-700 active:bg-neutral-700 dark:bg-neutral-50 dark:text-neutral-950 dark:hover:bg-neutral-300 dark:active:bg-neutral-300"
            >
              Expand all
            </button>
          </div>
          <div
            class="*:border-t *:border-neutral-200 lg:col-span-2 lg:-mt-3 *:dark:border-neutral-800"
          >
            {
              faq.map(({ question, answer }) => (
                <details class="group open:pb-8">
                  <summary class="flex cursor-pointer list-none py-6 font-medium text-neutral-950 transition group-open:pb-1 hover:text-neutral-500 active:text-neutral-500 dark:text-neutral-50">
                    <span class="w-6 shrink-0 before:content-['+'] group-open:before:content-['-']" />
                    {question}
                  </summary>
                  <p class="ml-6 text-neutral-700 dark:text-neutral-300">{answer}</p>
                </details>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<script>
  const button = document.getElementById('toggle-button');
  const details = document.querySelectorAll('details');
  let isExpanded = false;

  button?.addEventListener('click', () => {
    isExpanded = !isExpanded;
    details.forEach((d) => d.toggleAttribute('open', isExpanded));
    button.textContent = isExpanded ? 'Collapse all' : 'Expand all';
  });
</script>
