---
import BlocksIcon from 'lucide-astro/Blocks';
import CodeSquareIcon from 'lucide-astro/CodeSquare';
import DatabaseIcon from 'lucide-astro/Database';
import LaptopIcon from 'lucide-astro/Laptop';
import OcatagonAlertIcon from 'lucide-astro/OctagonAlert';
import SettingsIcon from 'lucide-astro/Settings';
import ShieldCheckIcon from 'lucide-astro/ShieldCheck';
import SparklesIcon from 'lucide-astro/Sparkles';
import WrenchIcon from 'lucide-astro/Wrench';
import MainLayout from '@layouts/MainLayout.astro';
import Divider from '@components/Divider.astro';
import { paths } from '@data/paths';
import PerformanceUI from '@assets/PerformanceUI.astro';

const title = 'Product';
const description =
  'We replace silos and fragmented operations with investment-grade data and turn it into measurable asset value.';

const process = [
  {
    title: 'Asset takeover',
    subtitle: 'A workshop with your asset and property manager',
    description:
      'We start with a site visit, then a workshop with your asset and property manager. Together we map how the building has been operated, what’s already being tracked, and where the current pain points are.',
    output:
      'A shared definition of what success looks like for this asset, and an agreed way of working between your team and ours.'
  },
  {
    title: 'Local integration & data gathering (2 weeks)',
    subtitle: 'Direct connection to your building systems',
    description:
      'We connect directly to your building infrastructure, not through third-party cloud APIs. With live data flowing, we produce a diagnostics report that identifies critical gaps, for example a missing main energy meter or a sensor needed for the baseline. We source and install only what’s essential to close major gaps.',
    output: 'The data foundation is in place within two weeks.'
  },
  {
    title: 'Setting the baseline',
    subtitle: 'A verified picture of your asset’s performance',
    description:
      'With live data flowing, we establish a clean, auditable performance baseline for the asset. This is the benchmark every future insight is measured against: energy consumption, system behaviour, operational patterns. From here, any deviation is visible. Any improvement is measurable.',
    output: 'A verified baseline that makes performance visible from day one.'
  },
  {
    title: 'Continuous intelligence',
    subtitle: 'Constantly unlocking the hidden value',
    description:
      'From baseline, reporting and fault detection run automatically. Energy and performance reports are generated from live meter data, always current, always audit-ready. Anomalies are flagged before they become maintenance calls or tenant complaints. Our team monitors the outputs and makes sure nothing falls through the cracks.',
    output: 'A continuously optimising asset, without adding work to your team.'
  }
];

const platform = [
  {
    title: 'Intelligence',
    description:
      'All data is securely stored in the cloud and always available via the Clouder Dashboard and a secure API. AI agents work on insights and data is also available through a MCP server for all internal use cases.',
    tags: ['CRE-native agents', 'API', 'Dashboard']
  },
  {
    title: 'Context',
    description:
      'Our data processing ensures accurate, comprehensive, and context-rich data that is immediately ready for artificial intelligence (AI) and machine learning (ML) applications.',
    tags: ['Integrations', 'Protocol conversions', 'Data preprocessing', 'Harmonization']
  },
  {
    title: 'Local integration',
    description:
      'All data is securely stored in the cloud and always available via the Clouder Dashboard and a secure API. AI agents work on insights and data is also available through a MCP server for all internal use cases.',
    tags: ['BMS', 'Energy metering', 'Water metering', 'Indoor climate', '50+ more…']
  }
];

const features = [
  {
    icon: BlocksIcon,
    title: 'Integration platform',
    content: [
      'Clouder performs integrations directly on-site, meaning we are not dependent on existing cabling, API’s, or BMS programming.',
      'On-site data processing ensures accurate, comprehensive, and context-rich data that is immediately ready for AI and ML applications.'
    ]
  },
  {
    icon: LaptopIcon,
    title: 'Clouder Dashboard',
    content: [
      'A centralized overview of your entire property with access to high-level insights and granular details.',
      'Track energy consumption and distribution with precision. Drill down to device and data point level when needed.  Export data effortlessly for reporting.'
    ]
  },
  {
    icon: SparklesIcon,
    title: 'Clouder agents',
    content: [
      'Multiple Clouder agents analyze your assets to give you valuable insights on their performance.',
      'The insights and data produced by agents is also available through MCP for all internal use cases.'
    ]
  },
  {
    icon: DatabaseIcon,
    title: 'Data storage',
    content: [
      'Cloud-based data storage accessible via Clouder Dashboard, API, and MCP. No more relying on benchmarks or estimates.',
      'Our five-year data retention policy gives you full ownership and control of your data.'
    ]
  },
  {
    icon: CodeSquareIcon,
    title: 'Real-time API',
    content: [
      'Access all building data through our real-time API.',
      'Ideal for smart office apps, property management software, and other third-party integrations.'
    ]
  },
  {
    icon: OcatagonAlertIcon,
    title: 'Fault detection & diagnostics',
    content: [
      'Quickly identify and diagnose faults, problems, and conflicts in your building automation system.',
      'Receive targeted recommendations and clear guidance for resolving identified issues.'
    ]
  },
  {
    icon: SettingsIcon,
    title: 'Device control',
    content: [
      'Control all systems and devices in your building without disrupting the existing building automation system.',
      'Use sophisticated, event-based rules to control devices to further reduce energy consumption.'
    ]
  },
  {
    icon: ShieldCheckIcon,
    title: 'Security built-in',
    content: [
      'Fine-grained data access rules, accurate audit trail, end-to-end encryption, and secure cloud storage of your building data.',
      'Robust security in building automation with centralized password management. No more default passwords known by everyone.'
    ]
  },
  {
    icon: WrenchIcon,
    title: 'Custom integrations',
    content: [
      'We can offer tailored solutions and consulting services to address your specific needs, from advanced system integrations to personalized building performance strategies.'
    ],
    showCta: true
  }
];

const faq = [
  {
    question: 'Where can Clouder be installed?',
    answer:
      'Clouder can be installed in all types of properties, both existing and new construction. Pilot buildings typically go live in two weeks. Portfolio rollouts then follow a repeatable playbook. Deployments are capex-light, minimally disruptive to tenants, and deliver value from day one.'
  },
  {
    question: 'How quickly can we implement Clouder across a portfolio?',
    answer:
      'Pilot buildings typically go live in two weeks. Portfolio rollouts then follow a repeatable playbook. Deployments are capex-light, minimally disruptive to tenants, and deliver value from day one.'
  },
  {
    question: 'Is Clouder compatible with our existing systems and vendors?',
    answer:
      'Yes. Clouder integrates with all major building protocols, for example BACnet and Modbus. Owners can retain their existing systems while unifying data into a clean, actionable layer.'
  },
  {
    question: 'What about cybersecurity and data ownership?',
    answer:
      'You retain full ownership and control of your data. Clouder applies end-to-end encryption, accurate audit trails, and secure cloud connections.'
  },
  {
    question: 'What are the annual costs? Are there any license fees?',
    answer:
      "Our pricing structure consists of a setup fee and a monthly subscription fee. The fees are determined by building size, complexity, data volume, selected features, and service scope. We don't charge any additional license fees for any of our plans."
  },
  {
    question: 'Which asset classes benefit most from Clouder?',
    answer:
      'Clouder scales across residential, office, logistics and mixed-use assets. Any building type with siloed systems benefits from reduced operating costs, improved sustainability metrics and higher valuations.'
  },
  {
    question: 'How does Clouder work with our existing ESG reporting software?',
    answer:
      'Clouder supplies the clean, unified data that ESG software depends on. This eliminates manual data collection, reduces errors, and ensures that operational efficiency gains show up clearly in compliance and valuation metrics. You can keep using your existing ESG-software. Clouder will serve clean data to that platform through the API.'
  },
  {
    question: 'How does Clouder help with EU Taxonomy and CSRD compliance?',
    answer:
      'Clouder integrates energy, water, indoor climate and automation data into one standardised layer. This makes reporting under EU Taxonomy and CSRD accurate and traceable.'
  },
  {
    question: 'Can Clouder improve our GRESB score?',
    answer:
      'Yes. By increasing data coverage and reducing consumption, Clouder strengthens the Management and Performance components of GRESB. Better metering, benchmarking and fault detection all contribute to higher scores and more attractive valuations.'
  }
];
---

<MainLayout title={title} description={description} headerClass="bg-neutral-50 dark:bg-neutral-950">
  <section
    class="bg-linear-to-b from-neutral-50 to-neutral-200 to-75% pt-24 pb-16 lg:pt-48 lg:pb-32 dark:from-neutral-950 dark:to-neutral-800"
  >
    <div class="container">
      <h1
        class="mb-4 font-serif text-4xl text-neutral-950 lg:mb-6 lg:text-6xl xl:text-7xl dark:text-neutral-50"
      >
        The new standard for<br class="hidden lg:block" /> property performance
      </h1>
      <p class="max-w-prose leading-normal text-balance lg:text-lg">
        {description}
      </p>
    </div>
    <div class="h-8 lg:h-16"></div>
    <div class="container">
      <PerformanceUI />
    </div>
    <div class="h-12 lg:h-24"></div>
    <div class="container">
      <div class="grid gap-x-4 gap-y-8 lg:grid-cols-4">
        <p class="mb-4 text-xs font-medium tracking-wider uppercase lg:mb-6">
          Commercial real estate<br class="hidden lg:block" /> portfolios carry hidden value
        </p>
        <div class="flex flex-col">
          <p class="mb-6 text-sm font-medium">Asset level hidden value</p>
          <p class="mt-auto font-serif text-5xl text-neutral-950 lg:text-7xl dark:text-neutral-50">
            15–40%
          </p>
          <p class="mt-2 h-8 text-sm leading-4 text-neutral-600 dark:text-neutral-400">
            Opex reduction potential
          </p>
        </div>
        <div class="flex flex-col">
          <p class="mb-6 text-sm font-medium">Outsourced management & external consultants</p>
          <p class="mt-auto font-serif text-5xl text-neutral-950 lg:text-7xl dark:text-neutral-50">
            69%
          </p>
          <p class="mt-2 h-8 text-sm leading-4 text-neutral-600 dark:text-neutral-400">
            Manual tasks automatable
          </p>
        </div>
        <div class="flex flex-col">
          <p class="mb-6 text-sm font-medium">Fund level operational efficiency</p>
          <p class="mt-auto font-serif text-3xl leading-8 text-neutral-950 dark:text-neutral-50">
            Portfolio-wide<br />savings
          </p>
          <p class="mt-2 h-8 text-sm leading-4 text-neutral-600 dark:text-neutral-400">
            Overhead reduction, removing reporting lag
          </p>
        </div>
      </div>
    </div>
  </section>
  <section class="py-16 lg:py-32">
    <div class="container">
      <div class="relative grid gap-8 lg:grid-cols-2">
        <div>
          <p class="mb-4 text-xs font-medium tracking-wider text-neutral-500 uppercase lg:mb-6">
            How we onboard your assets
          </p>
          <h2 class="font-serif text-3xl text-neutral-950 lg:text-5xl dark:text-neutral-50">
            A defined process for measurable result
          </h2>
        </div>
        <div class="lg:-mt-1">
          {
            process.map(({ title, subtitle, description, output }, i) => (
              <div class="group flex gap-6">
                <div class="flex flex-col items-center">
                  <div class="my-1 size-5 shrink-0 rounded-full border-7 border-neutral-200 bg-neutral-600 transition duration-300 group-hover:scale-110 group-hover:border-blue-100 group-hover:bg-blue-500 group-active:border-blue-100 group-active:bg-blue-500 dark:border-neutral-800 dark:bg-neutral-400 dark:group-hover:border-blue-900 dark:group-active:border-blue-900" />
                  <div
                    class:list={[
                      'h-full w-px border-l border-current/10 transition duration-300 group-hover:border-current/15 group-active:border-current/15',
                      i == process.length - 1 && 'border-dashed mask-b-from-0%'
                    ]}
                  />
                </div>
                <div class={i !== process.length - 1 ? 'pb-8 lg:pb-16' : undefined}>
                  <p class="text-lg font-medium text-neutral-950 dark:text-neutral-50">
                    Step {i + 1}: {title}
                  </p>
                  <p class="text-neutral-500">{subtitle}</p>
                  <p class="my-3 text-neutral-700 dark:text-neutral-300">{description}</p>
                  <p>
                    <span class="font-medium">Output: </span>
                    <span class="text-neutral-700 dark:text-neutral-300">{output}</span>
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>
  <Divider />
  <section class="py-16 lg:py-32">
    <div class="container">
      <p class="mb-4 text-xs font-medium tracking-wider text-neutral-500 uppercase lg:mb-6">
        Platfrom architecture
      </p>
      <h2 class="font-serif text-3xl text-neutral-950 lg:text-5xl dark:text-neutral-50">
        AI Platform architecture<br class="hidden lg:block" /> built for compounding value
      </h2>
      <div class="h-8 lg:h-16"></div>
      <div>
        {
          platform.map(({ title, description, tags }, i) => (
            <>
              <div class="group grid items-start gap-x-8 gap-y-4 lg:grid-cols-2">
                <div class="flex h-full flex-col items-center justify-center rounded-lg border border-neutral-200 p-8 pt-7 shadow-md shadow-black/2 transition duration-300 group-hover:border-neutral-300 group-hover:shadow-black/4 dark:border-neutral-800 dark:group-hover:border-neutral-700">
                  <p class="mb-3 text-sm leading-4 text-neutral-500 transition duration-300 group-hover:text-current">
                    {title}
                  </p>
                  <div class="flex flex-wrap items-center justify-center gap-1">
                    {tags.map((tag) => (
                      <span class="rounded border border-current/10 bg-current/4 px-3 py-1.5 text-xs leading-4 text-neutral-700 transition duration-300 group-hover:text-current dark:text-neutral-300">
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>
                <div class="lg:pl-11">
                  <p class="mb-2 text-lg font-medium text-neutral-950 dark:text-neutral-50">
                    {title}
                  </p>
                  <p class="text-neutral-700 dark:text-neutral-300">{description}</p>
                </div>
              </div>
              {i !== platform.length - 1 && (
                <div class="grid grid-cols-2 gap-8">
                  <div class="mx-auto h-8 border-dashed border-neutral-300 lg:block lg:h-16 lg:w-px lg:border-r dark:border-neutral-700" />
                </div>
              )}
            </>
          ))
        }
      </div>
    </div>
    <div class="h-16 lg:h-32"></div>
    <div class="container">
      <p class="mb-4 text-xs font-medium tracking-wider text-neutral-500 uppercase lg:mb-6">
        Feature overview
      </p>
      <div
        class="grid overflow-clip rounded-lg border border-neutral-200 md:grid-cols-2 lg:grid-cols-3 lg:grid-rows-3 dark:border-neutral-800"
      >
        {
          features.map(({ icon: Icon, title, content, showCta }, i) => (
            <div
              class:list={[
                'space-y-2 border-b border-neutral-200 p-8 lg:border-r lg:pb-16 dark:border-neutral-800',
                i % 3 === 2 && 'lg:border-r-0',
                i > features.length - 4 && 'lg:border-b-0'
              ]}
            >
              <Icon size={20} class="mb-3 shrink-0 text-neutral-500" />
              <h4 class="text-lg font-medium text-neutral-950 dark:text-neutral-50">{title}</h4>

              {content.map((p) => (
                <p class="text-neutral-700 dark:text-neutral-300">{p}</p>
              ))}
              {showCta && (
                <a
                  href={paths.contact.href}
                  class="mt-2 inline-flex h-9 cursor-pointer items-center justify-center rounded bg-neutral-950 px-3.5 text-center text-sm text-nowrap text-neutral-50 transition select-none hover:bg-neutral-700 active:bg-neutral-700 dark:bg-neutral-50 dark:text-neutral-950 dark:hover:bg-neutral-300 dark:active:bg-neutral-300"
                >
                  Let’s talk
                </a>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </section>
  <Divider />
  <section class="py-16 lg:py-32">
    <div class="container">
      <div class="grid grid-cols-1 items-start gap-8 lg:grid-cols-3">
        <div>
          <h2
            class="mb-4 font-serif text-3xl text-neutral-950 lg:mb-6 lg:text-5xl dark:text-neutral-50"
          >
            FAQ
          </h2>
          <button
            id="toggle-button"
            class="inline-flex h-9 cursor-pointer items-center justify-center rounded bg-neutral-950 px-3.5 text-center text-sm text-nowrap text-neutral-50 transition select-none hover:bg-neutral-700 active:bg-neutral-700 dark:bg-neutral-50 dark:text-neutral-950 dark:hover:bg-neutral-300 dark:active:bg-neutral-300"
          >
            Expand all
          </button>
        </div>
        <div
          class="*:border-t *:border-neutral-200 lg:col-span-2 lg:-mt-3 *:dark:border-neutral-800"
        >
          {
            faq.map(({ question, answer }) => (
              <details class="group open:pb-8">
                <summary class="flex cursor-pointer list-none py-6 text-lg font-medium text-neutral-950 transition group-open:pb-2 hover:text-neutral-500 active:text-neutral-500 dark:text-neutral-50">
                  <span class="w-6 shrink-0 before:content-['+'] group-open:before:content-['-']" />
                  {question}
                </summary>
                <p class="ml-6 text-neutral-700 dark:text-neutral-300">{answer}</p>
              </details>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <script>
    const button = document.getElementById('toggle-button');
    const details = document.querySelectorAll('details');
    let isExpanded = false;

    button?.addEventListener('click', () => {
      isExpanded = !isExpanded;
      details.forEach((d) => d.toggleAttribute('open', isExpanded));
      button.textContent = isExpanded ? 'Collapse all' : 'Expand all';
    });
  </script>
</MainLayout>
