            id="toggle-button"
            class="inline-flex h-9 cursor-pointer items-center justify-center rounded bg-neutral-950 px-3.5 text-center text-sm text-nowrap text-neutral-50 transition select-none hover:bg-neutral-700 active:bg-neutral-700 dark:bg-neutral-50 dark:text-neutral-950 dark:hover:bg-neutral-300 dark:active:bg-neutral-300"
          >
            Expand all
          </button>
        </div>
        <div
          class="*:border-t *:border-neutral-200 lg:col-span-2 lg:-mt-3 *:dark:border-neutral-800"
        >
          {
            faq.map(({ question, answer }) => (
              <details class="group open:pb-8">
                <summary class="flex cursor-pointer list-none py-6 font-medium text-neutral-950 transition group-open:pb-1 hover:text-neutral-500 active:text-neutral-500 dark:text-neutral-50">
                  <span class="w-6 shrink-0 before:content-['+'] group-open:before:content-['-']" />
                  {question}
                </summary>
                <p class="ml-6 text-neutral-700 dark:text-neutral-300">{answer}</p>
              </details>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<script>
  const button = document.getElementById('toggle-button');
  const details = document.querySelectorAll('details');
  let isExpanded = false;

  button?.addEventListener('click', () => {
    isExpanded = !isExpanded;
    details.forEach((d) => d.toggleAttribute('open', isExpanded));
    button.textContent = isExpanded ? 'Collapse all' : 'Expand all';
  });
</script>
