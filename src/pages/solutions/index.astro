                class="my-1 size-5 shrink-0 rounded-full border-7 border-neutral-200 bg-neutral-950 transition duration-300 group-hover:scale-105 group-hover:border-blue-100 group-hover:bg-blue-500 dark:border-neutral-800 dark:bg-neutral-50 dark:group-hover:border-blue-900"
              >
              </div>
              <div class="h-full w-px bg-current/10 pb-24"></div>
            </div>
            <div>
              <p class="mb-1 font-medium text-neutral-950 dark:text-neutral-50">Title</p>
              <p class="text-neutral-700 dark:text-neutral-300">
                Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer non arcu quis ipsum
                posuere aliquam. In ornare porta nunc, eu mollis ex.
              </p>
            </div>
