---
import MainLayout from '@layouts/MainLayout.astro';
// https://docs.netlify.com/forms/setup/#success-messages

const title = 'Thank you!';
const description = 'Your form submission has been received';
---

<MainLayout title={title}>
  <div class="px-6 py-32 text-center">
    <p class="mb-8 text-5xl">📬</p>
    <h1 class="mb-4 text-4xl font-medium text-neutral-950 dark:text-neutral-50">{title}</h1>
    <p class="mb-8">{description}</p>
    <a
      href="/"
      class="inline-flex h-10 cursor-pointer items-center justify-center gap-1 rounded bg-neutral-950 px-4 text-center text-sm font-medium text-nowrap text-neutral-50 transition select-none hover:bg-neutral-800 active:bg-neutral-800 dark:bg-neutral-50 dark:text-neutral-950 dark:hover:bg-neutral-200 dark:active:bg-neutral-200"
    >
      Back to home
    </a>
  </div>
</MainLayout>t
