---
import { getCollection } from 'astro:content';

import MainLayout from '@layouts/MainLayout.astro';
import Divider from '@components/Divider.astro';
import NewsHeader from '@components/NewsHeader.astro';
import Newsletter from '@components/Newsletter.astro';
import Post from '@components/Post.astro';
import { filterDrafts } from '@utils/content';

const posts = await getCollection('news', filterDrafts);
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const title = 'News';
const description = 'Company news, case examples, and more.';
---

<MainLayout title={title} description={description}>
  <NewsHeader />
  <section>
    <div class="pb-16 lg:pb-32">
      <div class="container">
        <div class="grid grid-cols-1 gap-x-8 gap-y-16 md:grid-cols-2 xl:grid-cols-6">
          {sortedPosts.map((post, index) => <Post isLarge={index < 4} post={post} />)}
        </div>
      </div>
    </div>
  </section>
  <Divider />
  <Newsletter />
</MainLayout>
