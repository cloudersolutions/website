---
import { getEntry, getCollection, render, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import ProseLayout from '@layouts/ProseLayout.astro';
import CompanyLogo from '@components/CompanyLogo.astro';
import Divider from '@components/Divider.astro';
import { paths } from '@data/paths';
import { formatDate } from '@utils/date';
import { filterDrafts, getCategoryLabel } from '@utils/content';
import { twMerge } from 'tailwind-merge';

export async function getStaticPaths() {
  const posts = await getCollection('news', filterDrafts);
  const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  return sortedPosts.map((post, index) => ({
    params: { id: post.id },
    props: {
      post,
      previousPost: sortedPosts[index - 1] || null,
      nextPost: sortedPosts[index + 1] || null
    }
  }));
}

interface Props {
  post: CollectionEntry<'news'>;
  previousPost: CollectionEntry<'news'> | null;
  nextPost: CollectionEntry<'news'> | null;
}

const { post, previousPost, nextPost } = Astro.props;
const { Content } = await render(post);

// The replace is for Pages CMS, since it won't give the reference without the extension…
const author = post.data.author ? await getEntry(post.data.author) : null;
---

<ProseLayout title={post.data.title} description={post.data.description} image={post.data.cover}>
  <article>
    <header class="not-prose">
      <h1
        class="font-serif text-4xl leading-[1.1] text-neutral-950 lg:text-5xl dark:text-neutral-50"
      >
        {post.data.title}
      </h1>
    </header>
    <aside class="not-prose top-26 right-0 pt-8 xl:absolute xl:pr-9.5">
      <ul class="grid grid-cols-2 gap-4 sm:grid-cols-4 xl:grid-cols-1">
        {
          author && (
            <li>
              <p class="text-sm">Author</p>
              <span class="text-sm text-neutral-500">{author.data.name}</span>
            </li>
          )
        }
        {
          post.data.category && (
            <li>
              <p class="text-sm">Category</p>
              <a
                class="text-sm text-neutral-500 underline-offset-2 hover:underline active:underline"
                href={`${paths.news.href}/${post.data.category}`}
              >
                {getCategoryLabel(post.data.category)}
              </a>
            </li>
          )
        }
        <li>
          <p class="text-sm">Date</p>
          <time class="text-sm text-neutral-500" datetime={post.data.date.toISOString()}>
            {formatDate(post.data.date)}
          </time>
        </li>
        <li>
          <p class="text-sm">Share</p>
          <button
            id="copy-clipboard"
            class="cursor-pointer text-left text-sm text-neutral-500 underline-offset-2 hover:underline active:underline"
          >
            Copy link
          </button>
        </li>
      </ul>
    </aside>
    {
      post.data.callout && post.data.category === 'case-study' && (
        <div class="not-prose mx-auto my-12 flex items-center border-y border-neutral-200 lg:my-16 dark:border-neutral-800">
          <div class="flex w-1/2 justify-center p-8 lg:p-16">
            <div>
              <p
                class:list={twMerge(
                  post.data.callout.value.length < 6
                    ? 'mb-1 text-4xl lg:text-5xl'
                    : 'mb-2 text-2xl lg:text-3xl',
                  'font-serif leading-none text-neutral-950 lg:max-w-48 dark:text-neutral-50'
                )}
              >
                {post.data.callout.value}
              </p>
              <p class="text-sm leading-none text-neutral-500">{post.data.callout.label}</p>
            </div>
          </div>
          <div class="w-px shrink-0 self-stretch bg-neutral-200 dark:bg-neutral-800" />
          <div class="flex w-1/2 justify-center p-16">
            <CompanyLogo
              company={post.data.callout.company}
              class="h-6 w-auto shrink-0 text-neutral-950 lg:h-8 dark:text-neutral-50"
            />
          </div>
        </div>
      )
    }
    <section class="my-12">
      <Content />
    </section>
    {
      author?.data.bio && post.data.showAuthorDetails && (
        <>
          <Divider />
          <section class="not-prose grid grid-cols-1 gap-4 lg:grid-cols-7">
            <div class="lg:col-span-3">
              <h3 class="font-serif text-2xl leading-8 lg:text-3xl">About the author</h3>
              <div class="mt-4 flex items-center gap-4 lg:mt-6">
                {author.data.image ? (
                  <Image
                    src={author.data.image}
                    alt=""
                    width={96}
                    layout="constrained"
                    class="aspect-square size-12 rounded-full object-cover object-center"
                  />
                ) : (
                  <div class="flex h-12 w-12 items-center justify-center rounded-full bg-neutral-500">
                    <span class="text-sm leading-none font-medium text-white uppercase">
                      {author.data.name
                        .split(' ')
                        .map((n) => n[0])
                        .join('')}
                    </span>
                  </div>
                )}
                <div>
                  <p class="text-base leading-5">{author.data.name}</p>
                  <p class="mt-0.5 text-sm leading-5 text-neutral-500">{author.data.title}</p>
                </div>
              </div>
            </div>
            <div class="lg:col-span-4">
              <p class="text-base">{author.data.bio}</p>
            </div>
          </section>
        </>
      )
    }
  </article>
  <Divider />
  <div class="not-prose">
    <nav class="grid gap-8 lg:grid-cols-2">
      {
        previousPost && (
          <a
            href={`${paths.news.href}/${previousPost.id}`}
            class="group text-center text-neutral-950 lg:text-left dark:text-neutral-50"
          >
            <p class="mb-1 text-sm text-neutral-500 transition group-hover:text-current group-active:text-current">
              <span class="inline-block opacity-60 transition group-hover:-translate-x-0.5 group-hover:opacity-100">
                &larr;
              </span>
              Previous
            </p>
            <p class="font-medium text-balance">{previousPost.data.title}</p>
          </a>
        )
      }
      {
        nextPost && (
          <a
            href={`${paths.news.href}/${nextPost.id}`}
            class="group text-center text-neutral-950 lg:col-start-2 lg:text-right dark:text-neutral-50"
          >
            <p class="-mr-0.75 text-sm text-neutral-500 transition group-hover:text-current group-active:text-current">
              Next
              <span class="inline-block opacity-60 transition group-hover:translate-x-0.5 group-hover:opacity-100">
                &rarr;
              </span>
            </p>
            <p class="font-medium text-balance">{nextPost.data.title}</p>
          </a>
        )
      }
    </nav>
  </div>
</ProseLayout>

<script>
  const button = document.getElementById('copy-clipboard');

  button?.addEventListener('click', () => {
    try {
      navigator.clipboard.writeText(window.location.href);
      button.textContent = 'Copied!';
      setTimeout(() => {
        button.textContent = 'Copy link';
      }, 3000);
    } catch (e) {
      console.log(e);
    }
  });
</script>
