---
import ChevronRightIcon from 'lucide-astro/ChevronRight';
import ChevronLeftIcon from 'lucide-astro/ChevronLeft';
import { formatNumber } from '@utils/format';
import { data } from './performanceData';
---

<div
  class="relative shrink-0 overflow-hidden rounded-xl bg-neutral-50 text-neutral-700 shadow-xl shadow-black/5 outline-[0.5px] outline-black/5 select-none dark:bg-neutral-900 dark:text-neutral-300 dark:shadow-black/20 dark:outline-white/5"
>
  <div
    class="absolute z-0 size-96 bg-radial-[at_0_0] from-white via-white via-25% to-transparent to-50% lg:size-180 dark:from-neutral-800/50 dark:via-neutral-800/25"
  >
  </div>
  <div class="relative flex flex-col lg:flex-row">
    <div class="w-full p-4 lg:p-6">
      <div class="flex items-start">
        <div class="mr-auto mb-2">
          <p class="text-base font-medium text-neutral-800 dark:text-neutral-200">
            Property performance
          </p>
          <p class="mt-0.5 text-sm text-neutral-500">
            Net heated area: {formatNumber(13500)} m²&ensp;&middot;&ensp;EPC: C
          </p>
        </div>
        <div class="flex rounded-md border border-neutral-200 dark:border-neutral-800">
          <button
            id="prevYear"
            class="p-1.5 transition hover:bg-current/5 disabled:pointer-events-none disabled:opacity-50"
          >
            <ChevronLeftIcon size={14} />
          </button>
          <span
            id="selectedYear"
            class="border-x border-neutral-200 px-2 text-xs leading-6.5 dark:border-neutral-800"
          >
            {data.curr.year.toString()}
          </span>
          <button
            id="nextYear"
            disabled
            class="p-1.5 transition hover:bg-current/5 disabled:pointer-events-none disabled:opacity-50"
          >
            <ChevronRightIcon size={14} />
          </button>
        </div>
      </div>
      <div class="mt-4">
        <canvas id="chart" class="block"></canvas>
      </div>
    </div>
    <div
      class="flex w-full shrink-0 flex-col gap-3 border-t border-neutral-200 p-4 lg:w-80 lg:border-t-0 lg:border-l lg:p-6 dark:border-neutral-800"
    >
      <p class="text-xs text-neutral-500">
        <span class="font-medium tracking-wider uppercase">Energy target</span>
        <span>(Budget)</span>
      </p>
      <div class="grid grid-cols-2 gap-1">
        <p class="text-sm">Original</p>
        <p id="budgetMwh" class="text-sm">{data.curr.budgetMwh}</p>
        <p class="text-sm">Adjusted</p>
        <p id="adjustedMwh" class="text-sm">{data.curr.adjustedMwh}</p>

        <p id="adjustedMwhDesc" class="col-span-full text-xs text-neutral-500">
          {data.curr.adjustedMwhDesc}
        </p>
      </div>
      <hr class="my-2 border-neutral-200 lg:-mx-6 dark:border-neutral-800" />
      <p class="text-xs text-neutral-500">
        <span id="forecastTitle" class="font-medium tracking-wider uppercase"
          >{data.curr.forecastTitle}</span
        >
        <span id="forecastTitleSub">{data.curr.forecastTitleSub}</span>
      </p>
      <div class="grid grid-cols-2 gap-1">
        <p class="text-sm">Consumption</p>
        <div class="flex items-center gap-1">
          <p id="actualMwh" class="text-sm">{data.curr.actualMwh}</p>
        </div>
        <p
          id="actualMwhDesc"
          class="col-span-full pr-4 text-xs text-neutral-500"
          set:html={data.curr.actualMwhDesc}
        />
      </div>
      <div class="grid grid-cols-2 gap-1">
        <p id="noiImpactTitle" class="text-sm">NOI impact</p>
        <p id="noiImpact" class="text-sm">{data.curr.noiImpact}</p>
      </div>
      <div class="grid grid-cols-2 gap-1">
        <p id="valuePotTitle" class="text-sm font-medium">Value potential</p>
        <p id="valuePot" class="text-sm font-medium">{data.curr.valuePot}</p>
        <p id="valuePotDesc" class="col-span-full pr-4 text-xs text-neutral-500">
          {data.curr.valuePotDesc}
        </p>
      </div>
    </div>
  </div>
</div>

<script>
  import Chart from 'chart.js/auto';
  import { data } from './performanceData.ts';

  let selectedYear = new Date().getFullYear();

  const ctx = document.getElementById('chart') as HTMLCanvasElement;
  const prevBtn = document.getElementById('prevYear') as HTMLButtonElement;
  const nextBtn = document.getElementById('nextYear') as HTMLButtonElement;
  const yearLabel = document.getElementById('selectedYear');
  const budgetMwh = document.getElementById('budgetMwh');
  const adjustedMwh = document.getElementById('adjustedMwh');
  const adjustedMwhDesc = document.getElementById('adjustedMwhDesc');
  const forecastTitle = document.getElementById('forecastTitle');
  const forecastTitleSub = document.getElementById('forecastTitleSub');
  const actualMwh = document.getElementById('actualMwh');
  const actualMwhDesc = document.getElementById('actualMwhDesc');
  const noiImpact = document.getElementById('noiImpact');
  const valuePot = document.getElementById('valuePot');
  const valuePotDesc = document.getElementById('valuePotDesc');

  const isMobile = window.matchMedia('(max-width: 1024px)').matches;
  const isDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
  const fg = '#737373';
  const fgDark = isDark ? '#d4d4d4' : '#262626';
  const bg = isDark ? '#262626' : '#fff';
  const border = isDark ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.08)';
  const borderDark = isDark ? 'rgba(255,255,255,0.12)' : 'rgba(0,0,0,0.12)';

  const months = [
    'January',
    'February',
    'March',
    'April',
    'May',
    'June',
    'July',
    'August',
    'September',
    'October',
    'November',
    'December'
  ];

  const verticalLinePlugin = {
    id: 'verticalLinePlugin',
    beforeDraw: (chart: any) => {
      if (chart.tooltip?._active && chart.tooltip._active.length) {
        const ctx = chart.ctx;
        ctx.save();
        const activePoint = chart.tooltip._active[0];
        ctx.beginPath();
        ctx.setLineDash([5, 5]);
        ctx.moveTo(activePoint.element.x, chart.chartArea.top);
        ctx.lineTo(activePoint.element.x, chart.chartArea.bottom);
        ctx.lineWidth = 1;
        ctx.strokeStyle = borderDark;
        ctx.stroke();
        ctx.restore();
      }
    }
  };

  const pointColor = (ctx: any, opacity: number) => {
    const target = ctx.chart.data.datasets[2];
    const dataset = ctx.chart.data.datasets[ctx.datasetIndex];
    const tValue = target.data[ctx.dataIndex];
    const pValue = dataset.data[ctx.dataIndex];
    return pValue > tValue ? `hsla(350,70%,50%,${opacity})` : `hsla(225,70%,50%,${opacity})`;
  };

  const segmentColor = (ctx: any, opacity: number) => {
    const target = ctx.chart.data.datasets[2];
    const dataset = ctx.chart.data.datasets[ctx.datasetIndex];
    const tValue = target.data[ctx.p1DataIndex];
    const pValue = dataset.data[ctx.p1DataIndex];
    return pValue > tValue ? `hsla(350,70%,50%,${opacity})` : `hsla(225,70%,50%,${opacity})`;
  };

  const segmentGradient = (ctx: any) => {
    const gradient = ctx.chart.ctx.createLinearGradient(0, 0, 0, ctx.chart.height);
    const startColor = segmentColor(ctx, 0.4);
    const stopColor = segmentColor(ctx, 0);
    gradient.addColorStop(0, startColor);
    gradient.addColorStop(1, stopColor);
    return gradient;
  };

  const chart = new Chart(ctx, {
    type: 'line',
    data: {
      labels: ['', ...months.map((m) => m.substring(0, 3))],
      datasets: [
        {
          label: 'Actual',
          data: data.curr.actual,
          borderWidth: 2,
          borderCapStyle: 'round',
          fill: 'origin',
          tension: 0.3,
          pointStyle: 'circle',
          pointHoverRadius: 3,
          pointRadius: 0,
          pointBorderColor: (ctx) => pointColor(ctx, 1),
          pointBackgroundColor: (ctx) => pointColor(ctx, 1),
          segment: {
            borderColor: (ctx) => segmentColor(ctx, 1),
            backgroundColor: (ctx) => segmentGradient(ctx)
          }
        },
        {
          label: 'Estimate',
          data: data.curr.estimate,
          borderColor: '#e2783666',
          backgroundColor: 'transparent',
          borderWidth: 2,
          borderDash: [6, 6],
          borderCapStyle: 'round',
          tension: 0.3,
          pointStyle: 'circle',
          pointBorderColor: (ctx) => pointColor(ctx, 0.5),
          pointBackgroundColor: (ctx) => pointColor(ctx, 0.5),
          pointHoverRadius: 3,
          pointRadius: 0,
          segment: {
            borderColor: (ctx) => segmentColor(ctx, 0.5)
          }
        },
        {
          label: 'Target',
          data: Array.from({ length: 13 }, (_, i) => (i / 12) * 100),
          borderColor: 'gray',
          backgroundColor: 'gray',
          borderWidth: 2,
          borderCapStyle: 'round',
          pointStyle: 'circle',
          pointHoverRadius: 3,
          pointRadius: 0,
          fill: false
        }
      ]
    },
    options: {
      responsive: true,
      aspectRatio: isMobile ? 1.75 : 2.25,
      animation: {
        duration: 200,
        easing: 'easeOutSine'
      },
      plugins: {
        tooltip: {
          enabled: true,
          caretSize: 0,
          caretPadding: 20,
          padding: {
            left: 16,
            right: 16,
            top: 14,
            bottom: 12
          },
          backgroundColor: bg,
          borderWidth: 1,
          borderColor: borderDark,
          titleColor: fgDark,
          titleFont: { weight: 600 },
          bodyColor: fgDark,
          footerSpacing: 0,
          footerMarginTop: 2,
          footerColor: fgDark,
          footerFont: {
            weight: 400
          },
          filter: (tooltipItem) => {
            return tooltipItem.dataIndex !== 0;
          },
          callbacks: {
            title: (item) => {
              if (item.length === 0) return;
              const month = months[item[0].dataIndex - 1];
              const monthPart = item.some((i) => i.datasetIndex === 0)
                ? month
                : `${month} (estimate)`;
              const yearPart = selectedYear === new Date().getFullYear() ? null : selectedYear;
              return [monthPart, yearPart].filter(Boolean).join(', ');
            },
            label: () => '',
            footer: (item) => {
              if (item.length === 0) return;
              const diff = Number(item[0].raw) - Number(item[item.length - 1].raw);
              if (isNaN(diff)) return '–';
              const absDiff = Math.abs(diff).toFixed(1);
              if (diff > 0) return `${absDiff}% above adjusted target`;
              return `${absDiff}% below adjusted target`;
            }
          }
        },
        legend: {
          display: false
        }
      },
      interaction: {
        mode: 'index',
        intersect: false,
        axis: 'x'
      },
      scales: {
        x: {
          offset: false,
          border: {
            display: false
          },
          grid: {
            display: false
          },
          ticks: {
            color: fg
          }
        },
        y: {
          border: {
            display: false
          },
          grid: {
            display: true,
            color: border
          },
          ticks: {
            color: fg,
            padding: 4,
            maxTicksLimit: 9,
            callback: (value) => `${value}%`
          },
          beginAtZero: true
        }
      }
    },
    plugins: [verticalLinePlugin]
  });

  Chart.defaults.font.family = 'InterVariable, sans-serif';

  function updateSidebar(data: any) {
    if (yearLabel) yearLabel.textContent = data.year.toString();
    if (budgetMwh) budgetMwh.textContent = data.budgetMwh;
    if (adjustedMwh) adjustedMwh.textContent = data.adjustedMwh;
    if (adjustedMwhDesc) adjustedMwhDesc.textContent = data.adjustedMwhDesc;
    if (forecastTitle) forecastTitle.textContent = data.forecastTitle;
    if (forecastTitleSub) forecastTitleSub.textContent = data.forecastTitleSub;
    if (noiImpact) noiImpact.textContent = data.noiImpact;
    if (valuePot) valuePot.textContent = data.valuePot;
    if (valuePotDesc) valuePotDesc.textContent = data.valuePotDesc;
    if (actualMwh) actualMwh.textContent = data.actualMwh;
    if (actualMwhDesc) actualMwhDesc.innerHTML = data.actualMwhDesc;

    if (data.year === new Date().getFullYear()) {
      nextBtn.disabled = true;
      prevBtn.disabled = false;
    } else {
      nextBtn.disabled = false;
      prevBtn.disabled = true;
    }
  }

  prevBtn?.addEventListener('click', () => {
    updateSidebar(data.prev);
    chart.data.datasets[0].data = data.prev.actual;
    chart.data.datasets[1].data = data.prev.estimate;
    chart.update();
  });

  nextBtn?.addEventListener('click', () => {
    updateSidebar(data.curr);
    chart.data.datasets[0].data = data.curr.actual;
    chart.data.datasets[1].data = data.curr.estimate;
    chart.update();
  });
</script>
