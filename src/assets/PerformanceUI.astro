---
import { DateTime } from 'luxon';
import InfoIcon from 'lucide-astro/Info';
import TrendingUpIcon from 'lucide-astro/TrendingUp';
import TrendingDownIcon from 'lucide-astro/TrendingDown';
import ChevronRightIcon from 'lucide-astro/ChevronRight';
import ChevronLeftIcon from 'lucide-astro/ChevronLeft';
import { formatNumber } from '@utils/format';
import { data } from './performanceData';
---

<div
  class="relative shrink-0 overflow-hidden rounded-xl bg-neutral-50 text-neutral-700 shadow-xl shadow-black/5 outline-[0.5px] outline-black/5 select-none dark:bg-neutral-900 dark:text-neutral-300 dark:shadow-black/20 dark:outline-white/5"
>
  <div
    class="absolute z-0 size-96 bg-radial-[at_0_0] from-white via-white via-25% to-transparent to-50% lg:size-180 dark:from-neutral-800/50 dark:via-neutral-800/25"
  >
  </div>
  <div class="relative flex flex-col lg:flex-row">
    <div class="w-full p-4 lg:p-6">
      <div class="flex items-start">
        <div class="mr-auto mb-2">
          <p class="text-base font-medium text-neutral-800 dark:text-neutral-200">
            Property performance
          </p>
          <p class="mt-0.5 text-sm text-neutral-500">
            Area: {formatNumber(13500)} m²&ensp;&middot;&ensp;EPC: C
          </p>
        </div>
        <div class="flex rounded border border-neutral-200 dark:border-neutral-800">
          <button id="prevYear" class="p-1.5 transition hover:bg-current/5">
            <ChevronLeftIcon size={14} />
          </button>
          <span
            id="selectedYear"
            class="border-x border-neutral-200 px-3 text-xs leading-6.5 dark:border-neutral-800"
          >
            {DateTime.now().year}
          </span>
          <button id="nextYear" class="p-1.5 transition hover:bg-current/5">
            <ChevronRightIcon size={14} />
          </button>
        </div>
      </div>
      <div class="lg:aspect-wide mt-4 aspect-square">
        <canvas id="chart" class="block"></canvas>
      </div>
    </div>
    <div
      class="flex w-full flex-col gap-3 border-t border-neutral-200 p-4 lg:w-96 lg:gap-4 lg:border-t-0 lg:border-l lg:p-6 dark:border-neutral-800"
    >
      <p class="text-xs font-medium tracking-wider text-neutral-500 uppercase">Energy target</p>
      <div class="grid grid-cols-2 gap-1">
        <p class="text-[13px]">Budget</p>
        <p id="budgetMwh" class="text-[13px]">{data.curr.budgetMwh}</p>
        <p class="text-[13px]">Adjusted</p>
        <p id="adjustedMwh" class="text-[13px]">{data.curr.adjustedMwh}</p>

        <p id="adjustedMwhDesc" class="col-span-full pr-4 text-xs text-neutral-500">
          {data.curr.adjustedMwhDesc}
        </p>
      </div>
      <hr class="my-2 border-neutral-200 lg:-mx-6 dark:border-neutral-800" />
      <p id="forecastTitle" class="text-xs font-medium tracking-wider text-neutral-500 uppercase">
        {data.curr.forecastTitle}
      </p>
      <div class="grid grid-cols-2 gap-1">
        <p id="valuePotTitle" class="text-sm">{data.curr.valuePotTitle}</p>
        <p id="valuePot" class="text-sm">{data.curr.valuePot}</p>
        <p id="valuePotDesc" class="col-span-full pr-4 text-xs text-neutral-500">
          {data.curr.valuePotDesc}
        </p>
      </div>
      <div class="grid grid-cols-2 gap-1">
        <p class="text-sm">Consumption</p>
        <div class="flex items-center gap-1">
          <p id="actualMwh" class="text-sm">{data.curr.actualMwh}</p>
          <TrendingDownIcon size={14} class="iconDown text-blue-600 dark:text-blue-400" />
          <TrendingUpIcon size={14} class="hidden text-orange-600 dark:text-orange-400" />
        </div>
        <p id="actualMwhDesc" class="col-span-full pr-4 text-xs text-neutral-500">
          {data.curr.actualMwhDesc}
        </p>
      </div>
      <div class="grid grid-cols-2 gap-1">
        <p class="text-sm">Energy intensity</p>
        <div class="flex items-center gap-1">
          <p id="kwhPsm" class="text-sm">{data.curr.kwhPsm}</p>
          <TrendingDownIcon size={14} class="iconDown text-blue-600 dark:text-blue-400" />
          <TrendingUpIcon size={14} class="hidden text-orange-600 dark:text-orange-400" />
        </div>
        <p class="col-span-full text-xs text-neutral-500">Target: {formatNumber(96)} kWh/m²</p>
      </div>
      <div class="grid grid-cols-2 gap-1">
        <p class="text-sm">CO₂ Emissions</p>
        <div class="flex items-center gap-1">
          <p id="kgCo2Psm" class="text-sm">{data.curr.kgCo2Psm}</p>
          <TrendingDownIcon size={14} class="iconDown text-blue-600 dark:text-blue-400" />
          <TrendingUpIcon size={14} class="hidden text-orange-600 dark:text-orange-400" />
        </div>
        <p class="col-span-full text-xs text-neutral-500">Target: {formatNumber(20)}kg CO₂e/m²</p>
      </div>
    </div>
  </div>
</div>

<script>
  import Chart from 'chart.js/auto';
  import { data } from './performanceData.ts';

  let selectedYear = new Date().getFullYear();

  const ctx = document.getElementById('chart') as HTMLCanvasElement;
  const prevBtn = document.getElementById('prevYear');
  const nextBtn = document.getElementById('nextYear');
  const yearLabel = document.getElementById('selectedYear');
  const budgetMwh = document.getElementById('budgetMwh');
  const adjustedMwh = document.getElementById('adjustedMwh');
  const adjustedMwhDesc = document.getElementById('adjustedMwhDesc');
  const forecastTitle = document.getElementById('forecastTitle');
  const actualMwh = document.getElementById('actualMwh');
  const actualMwhDesc = document.getElementById('actualMwhDesc');
  const valuePotTitle = document.getElementById('valuePotTitle');
  const valuePot = document.getElementById('valuePot');
  const valuePotDesc = document.getElementById('valuePotDesc');
  const kwhPsm = document.getElementById('kwhPsm');
  const kgCo2Psm = document.getElementById('kgCo2Psm');

  const iconUps = document.querySelectorAll<HTMLElement>('svg.lucide-trending-up');
  const iconDowns = document.querySelectorAll<HTMLElement>('svg.lucide-trending-down');

  const isMobile = window.matchMedia('(max-width: 1024px)').matches;
  const isDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
  const fg = isDark ? '#737373' : '#a3a3a3';
  const fgDark = isDark ? '#d4d4d4' : '#262626';
  const bg = isDark ? '#262626' : '#fff';
  const border = isDark ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.08)';
  const borderDark = isDark ? 'rgba(255,255,255,0.12)' : 'rgba(0,0,0,0.12)';

  const months = [
    'January',
    'February',
    'March',
    'April',
    'May',
    'June',
    'July',
    'August',
    'September',
    'October',
    'November',
    'December'
  ];

  const verticalLinePlugin = {
    id: 'verticalLinePlugin',
    beforeDraw: (chart: any) => {
      if (chart.tooltip?._active && chart.tooltip._active.length) {
        const ctx = chart.ctx;
        ctx.save();
        const activePoint = chart.tooltip._active[0];
        ctx.beginPath();
        ctx.setLineDash([5, 5]);
        ctx.moveTo(activePoint.element.x, chart.chartArea.top);
        ctx.lineTo(activePoint.element.x, chart.chartArea.bottom);
        ctx.lineWidth = 1;
        ctx.strokeStyle = borderDark;
        ctx.stroke();
        ctx.restore();
      }
    }
  };

  const segmentColor = (ctx: any, opacity: number) => {
    const target = ctx.chart.data.datasets[0];
    const tValue = target.data[ctx.p1DataIndex];
    const dataset = ctx.chart.data.datasets[ctx.datasetIndex];
    const pValue = dataset.data[ctx.p1DataIndex];
    return pValue > tValue ? `rgba(226,120,54,${opacity})` : `rgba(65,105,225,${opacity})`;
  };

  const pointColor = (ctx: any, opacity: number) => {
    const target = ctx.chart.data.datasets[0];
    const dataset = ctx.chart.data.datasets[ctx.datasetIndex];
    const pValue = dataset.data[ctx.dataIndex];
    const tValue = target.data[ctx.dataIndex];
    return pValue > tValue ? `rgba(226,120,54,${opacity})` : `rgba(65,105,225,${opacity})`;
  };

  const chart = new Chart(ctx, {
    type: 'line',
    data: {
      labels: ['', ...months.map((m) => m.substring(0, 3))],
      datasets: [
        {
          label: 'Target',
          data: [
            0, 8.3333333333, 16.6666666666, 24.9999999999, 33.3333333333, 41.6666666666,
            49.9999999999, 58.3333333333, 66.6666666666, 74.9999999999, 83.333333333, 91.6666666666,
            100
          ],
          borderColor: 'gray',
          backgroundColor: 'gray',
          borderWidth: 2,
          borderCapStyle: 'round',
          pointStyle: 'circle',
          pointHoverRadius: 3,
          pointRadius: 0,
          fill: false
        },
        {
          label: 'Actual',
          data: data.curr.actual,
          borderWidth: 2,
          borderCapStyle: 'round',
          fill: 'origin',
          tension: 0.3,
          pointStyle: 'circle',
          pointHoverRadius: 3,
          pointRadius: 0,
          pointBorderColor: (ctx) => pointColor(ctx, 1),
          pointBackgroundColor: (ctx) => pointColor(ctx, 1),
          segment: {
            borderColor: (ctx) => segmentColor(ctx, 1),
            backgroundColor: (ctx) => segmentColor(ctx, 0.12)
          }
        },
        {
          label: 'Estimate',
          data: data.curr.estimate,
          borderColor: '#e2783666',
          backgroundColor: 'transparent',
          borderWidth: 2,
          borderDash: [6, 6],
          borderCapStyle: 'round',
          tension: 0.3,
          pointStyle: 'circle',
          pointBorderColor: (ctx) => pointColor(ctx, 0.5),
          pointBackgroundColor: (ctx) => pointColor(ctx, 0.5),
          pointHoverRadius: 3,
          pointRadius: 0,
          segment: {
            borderColor: (ctx) => segmentColor(ctx, 0.5)
          }
        }
      ]
    },
    options: {
      responsive: true,
      aspectRatio: isMobile ? 1 : 2,
      animation: {
        duration: 300
      },
      plugins: {
        tooltip: {
          enabled: true,
          caretSize: 0,
          caretPadding: 20,
          padding: {
            left: 12,
            right: 16,
            top: 11,
            bottom: 10
          },
          backgroundColor: bg,
          borderWidth: 1,
          borderColor: borderDark,
          titleColor: fgDark,
          titleFont: { weight: 600 },
          bodyColor: fgDark,
          footerSpacing: 0,
          footerMarginTop: 2,
          footerColor: fgDark,
          footerFont: {
            weight: 400
          },
          filter: (tooltipItem) => {
            return tooltipItem.dataIndex !== 0;
          },
          callbacks: {
            title: (item) => {
              if (item.length === 0) return;
              const month = months[item[0].dataIndex - 1];
              const monthPart = item.some((i) => i.datasetIndex === 1)
                ? month
                : `${month} (estimate)`;
              const yearPart = selectedYear === new Date().getFullYear() ? null : selectedYear;
              return [monthPart, yearPart].filter(Boolean).join(', ');
            },
            label: () => '',
            footer: (item) => {
              if (item.length === 0) return;
              const diff = Number(item[1].raw) - Number(item[0].raw);
              if (isNaN(diff)) return '–';
              const absDiff = Math.abs(diff).toFixed(1);
              if (diff > 0) return `+${absDiff}% above target`;
              return `-${absDiff}% below target`;
            }
          }
        },
        legend: {
          display: false
        }
      },
      interaction: {
        mode: 'index',
        intersect: false,
        axis: 'x'
      },
      scales: {
        x: {
          offset: false,
          border: {
            display: false
          },
          grid: {
            display: false
          },
          ticks: {
            color: fg
          }
        },
        y: {
          border: {
            display: false
          },
          grid: {
            display: true,
            color: border
          },
          ticks: {
            color: fg,
            padding: 4,
            maxTicksLimit: 9,
            callback: (value) => `${value}%`
          },
          beginAtZero: true
        }
      }
    },
    plugins: [verticalLinePlugin]
  });

  Chart.defaults.font.family = 'InterVariable';

  prevBtn?.addEventListener('click', () => {
    selectedYear = Math.min(selectedYear, new Date().getFullYear() - 1);

    if (yearLabel) yearLabel.textContent = selectedYear.toString();
    if (budgetMwh) budgetMwh.textContent = data.prev.budgetMwh;
    if (adjustedMwh) adjustedMwh.textContent = data.prev.adjustedMwh;
    if (adjustedMwhDesc) adjustedMwhDesc.textContent = data.prev.adjustedMwhDesc;
    if (forecastTitle) forecastTitle.textContent = data.prev.forecastTitle;
    if (valuePotTitle) valuePotTitle.textContent = data.prev.valuePotTitle;
    if (valuePot) valuePot.textContent = data.prev.valuePot;
    if (valuePotDesc) valuePotDesc.textContent = data.prev.valuePotDesc;
    if (actualMwh) actualMwh.textContent = data.prev.actualMwh;
    if (actualMwhDesc) actualMwhDesc.textContent = data.prev.actualMwhDesc;
    if (kwhPsm) kwhPsm.textContent = data.prev.kwhPsm;
    if (kgCo2Psm) kgCo2Psm.textContent = data.prev.kgCo2Psm;
    iconUps.forEach((icon) => (icon.style.display = 'block'));
    iconDowns.forEach((icon) => (icon.style.display = 'none'));

    chart.data.datasets[1].data = data.prev.actual;
    chart.data.datasets[2].data = data.prev.estimate;
    chart.update();
  });

  nextBtn?.addEventListener('click', () => {
    selectedYear = Math.min(selectedYear + 1, new Date().getFullYear());

    chart.data.datasets[1].data = data.curr.actual;
    chart.data.datasets[2].data = data.curr.estimate;
    chart.update();

    if (yearLabel) yearLabel.textContent = selectedYear.toString();
    if (budgetMwh) budgetMwh.textContent = data.curr.budgetMwh;
    if (adjustedMwh) adjustedMwh.textContent = data.curr.adjustedMwh;
    if (adjustedMwhDesc) adjustedMwhDesc.textContent = data.curr.adjustedMwhDesc;
    if (forecastTitle) forecastTitle.textContent = data.curr.forecastTitle;
    if (valuePotTitle) valuePotTitle.textContent = data.curr.valuePotTitle;
    if (valuePot) valuePot.textContent = data.curr.valuePot;
    if (valuePotDesc) valuePotDesc.textContent = data.curr.valuePotDesc;
    if (actualMwh) actualMwh.textContent = data.curr.actualMwh;
    if (actualMwhDesc) actualMwhDesc.textContent = data.curr.actualMwhDesc;
    if (kwhPsm) kwhPsm.textContent = data.curr.kwhPsm;
    if (kgCo2Psm) kgCo2Psm.textContent = data.curr.kgCo2Psm;
    iconUps.forEach((icon) => (icon.style.display = 'none'));
    iconDowns.forEach((icon) => (icon.style.display = 'block'));
  });
</script>
