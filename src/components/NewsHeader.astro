---
import { getCollection } from 'astro:content';

import { paths } from '@data/paths';
import { filterDrafts, categories } from '@utils/content';

interface Props {
  current?: string;
}

const { current } = Astro.props;

const posts = await getCollection('news', filterDrafts);
const usedCategories = Array.from(new Set(posts.map(({ data }) => data.category)));
const nonEmptyCategories = categories.filter((c) => usedCategories.includes(c.value));

const linkClass =
  'inline-flex items-center text-sm py-2 font-[420] text-neutral-600 dark:text-neutral-400 hover:text-current px-3 leading-4 rounded-md transition select-none hover:bg-current/5 active:bg-current/5 aria-current:text-neutral-50 aria-current:bg-neutral-950 dark:aria-current:text-neutral-950 dark:aria-current:bg-neutral-50';
---

<div class="pt-16 pb-12 lg:pt-32 lg:pb-16">
  <div class="container">
    <h1
      class="mb-4 font-serif text-4xl text-neutral-950 lg:mb-6 lg:text-6xl xl:text-5xl dark:text-neutral-50"
    >
      The latest from Clouder
    </h1>
    <div class="flex flex-wrap items-center gap-1 text-neutral-950 dark:text-neutral-50">
      <a href={paths.news.href} aria-current={current === undefined} class={linkClass}>All</a>
      {
        nonEmptyCategories.map((category) => (
          <a
            href={`${paths.news.href}/${category.value}`}
            aria-current={current === category.value}
            class={linkClass}
          >
            {category.label}
          </a>
        ))
      }
    </div>
  </div>
</div>
