---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { twMerge } from 'tailwind-merge';
import CompanyLogo from '@components/CompanyLogo.astro';
import { paths } from '@data/paths';

interface Props {
  post: CollectionEntry<'news'> & {
    data: CollectionEntry<'news'>['data'] & {
      callout: NonNullable<CollectionEntry<'news'>['data']['callout']>;
    };
  };
}

const { post } = Astro.props;
---

<article class="group lg:aspect-3/1">
  <a href={`${paths.news.href}/${post.id}`} class="flex h-full flex-col lg:flex-row">
    <div
      class="bg-linear relative flex shrink-0 justify-between bg-black p-8 text-neutral-50 lg:w-1/3 lg:flex-col"
    >
      <Image
        src={post.data.cover}
        alt={post.data.coverAlt}
        width={240}
        layout="full-width"
        class="absolute inset-0 size-full object-cover text-transparent opacity-30 transition duration-300 group-hover:opacity-35 group-active:opacity-35"
      />
      <div class="relative drop-shadow-[0_0_16px] drop-shadow-black/50">
        <p
          class:list={twMerge(
            post.data.callout.value.length < 6 ? 'text-5xl lg:text-7xl' : 'text-3xl leading-8',
            'font-serif'
          )}
        >
          {post.data.callout.value}
        </p>
        <p class="mt-2 text-sm opacity-75">{post.data.callout.label}</p>
      </div>
      <CompanyLogo
        company={post.data.callout.company}
        class="relative h-6 w-fit shrink-0 drop-shadow-[0_0_16px] drop-shadow-black/50"
      />
    </div>
    <div
      class="flex flex-col justify-between border border-t-0 border-neutral-200 p-8 lg:border-t lg:border-l-0 dark:border-neutral-800"
    >
      <p
        class="mb-8 pr-8 -indent-[0.45em] font-serif text-xl text-balance text-neutral-950 lg:text-2xl dark:text-neutral-50"
      >
        &ldquo;&hairsp;{post.data.callout.quote}&rdquo;
      </p>
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="text-sm font-medium text-neutral-950 dark:text-neutral-50">
            {post.data.callout.name}
          </p>
          <p class="text-sm leading-4 text-neutral-500">{post.data.callout.title}</p>
        </div>
        <p
          class="text-sm leading-4 text-neutral-500 transition group-hover:text-current group-active:text-current"
        >
          View case study
          <span
            class="inline-block opacity-60 transition group-hover:translate-x-0.5 group-hover:opacity-100"
          >
            &rarr;
          </span>
        </p>
      </div>
    </div>
  </a>
</article>
