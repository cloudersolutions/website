---
import ArrowUpRightIcon from 'lucide-astro/ArrowUpRight';

import config from '@data/config.yml';
import { sitemapLinks, resourcesLinks, socialLinks } from '@data/paths';
import Logo from '@components/Logo.astro';
import Divider from '@components/Divider.astro';

const isExternal = (href: string) => {
  return href.startsWith('http');
};
---

<Divider />
<footer>
  <div class="py-8 lg:py-16">
    <div class="container">
      <div class="grid grid-cols-1 gap-8 sm:grid-cols-9">
        <div class="order-last sm:order-first sm:col-span-3">
          <a href="/" class="inline-block">
            <Logo size={15} class="shrink-0 text-neutral-950 dark:text-neutral-50" />
          </a>
          <p class="mt-3 text-xs text-neutral-500">
            &copy; {new Date().getFullYear()}
            {config.title}
          </p>
        </div>
        <div class="flex flex-col items-start gap-1 sm:col-span-2">
          <h4 class="mb-1 text-sm font-medium text-neutral-950 dark:text-neutral-50">Sitemap</h4>
          {
            sitemapLinks.map(({ title, href }) => (
              <a
                href={href}
                class="inline-flex items-center gap-0.5 py-1 text-sm text-neutral-500 transition hover:text-current active:text-current"
              >
                {title}
                {isExternal(href) && (
                  <ArrowUpRightIcon size={14} class="mt-px shrink-0 opacity-50" />
                )}
              </a>
            ))
          }
        </div>
        <div class="flex flex-col items-start gap-1 sm:col-span-2">
          <h4 class="mb-1 text-sm font-medium text-neutral-950 dark:text-neutral-50">Resources</h4>
          {
            resourcesLinks.map(({ title, href }) => (
              <a
                href={href}
                class="inline-flex items-center gap-0.5 py-1 text-sm text-neutral-500 transition hover:text-current active:text-current"
              >
                {title}
                {isExternal(href) && (
                  <ArrowUpRightIcon size={14} class="mt-px shrink-0 opacity-50" />
                )}
              </a>
            ))
          }
        </div>
        <div class="flex flex-col items-start gap-1 sm:col-span-2">
          <h4 class="mb-1 text-sm font-medium text-neutral-950 dark:text-neutral-50">Follow</h4>
          {
            socialLinks.map(({ title, href }) => (
              <a
                href={href}
                class="inline-flex items-center gap-0.5 py-1 text-sm text-neutral-500 transition hover:text-current active:text-current"
              >
                {title}
                <ArrowUpRightIcon size={14} class="mt-px shrink-0 opacity-50" />
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</footer>
