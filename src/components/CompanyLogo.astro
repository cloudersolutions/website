---
import AreimLogo from '@assets/areim.svg';
import AvantLogo from '@assets/avant.svg';
import ConficapLogo from '@assets/conficap.svg';
import LifelineLogo from '@assets/lifeline.svg';
import LahiTapiolaLogo from '@assets/lahitapiola.svg';
import PatriaLogo from '@assets/patria.svg';
import SkanskaLogo from '@assets/skanska.svg';
import SrvLogo from '@assets/srv.svg';
import VarteLogo from '@assets/varte.svg';
import EmptySvg from '@assets/empty.svg';

interface Props {
  company: string;
  class?: string;
}

const { company, class: className } = Astro.props;

// Keep in sync with .pages.yml
const Logo = (() => {
  switch (company.toLowerCase().replace(/\s/g, '')) {
    case 'areim':
      return AreimLogo;
    case 'avant':
      return AvantLogo;
    case 'conficap':
      return ConficapLogo;
    case 'lifeline':
      return LifelineLogo;
    case 'lahitapiola':
    case 'lähitapiola':
      return LahiTapiolaLogo;
    case 'patria':
      return PatriaLogo;
    case 'skanska':
      return SkanskaLogo;
    case 'srv':
      return SrvLogo;
    case 'varte':
      return VarteLogo;
    default:
      console.warn(`⚠️ Unknown company "${company}"`);
      return EmptySvg;
  }
})();
---

<Logo class={className} />
