---
import type { AstroComponentFactory } from 'astro/runtime/server/index.js';

interface Props {
  quote: string;
  citeName: string;
  citeTitle: string;
  citeLogo: AstroComponentFactory & ImageMetadata;
}

const { quote, citeName, citeTitle, citeLogo: Logo } = Astro.props;
---

<blockquote class="flex flex-col items-start justify-between rounded-md">
  <p
    class="max-w-prose py-4 -indent-[0.45em] text-xl leading-normal font-medium text-neutral-900 italic dark:text-neutral-100"
  >
    &ldquo;{quote}&rdquo;
  </p>
  <div class="flex items-center gap-4 pt-4">
    <Logo class="h-6 w-auto" />
    <div class="h-full w-px bg-current/10"></div>
    <div>
      <p class="text-sm font-medium">{citeName}</p>
      <p class="mt-0.5 text-sm text-neutral-500">{citeTitle}</p>
    </div>
  </div>
</blockquote>
