---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { twMerge } from 'tailwind-merge';
import ChevronRightIcon from 'lucide-astro/ChevronRight';
import CompanyLogo from '@components/CompanyLogo.astro';
import { paths } from '@data/paths';

interface Props {
  post: CollectionEntry<'news'>;
}

const { post } = Astro.props;
---

<article class="group">
  <a href={`${paths.news.href}/${post.id}`} class="flex h-full flex-col">
    <Image
      src={post.data.cover}
      alt={post.data.coverAlt}
      width={720}
      layout="constrained"
      class="aspect-video bg-neutral-500/10 object-cover text-transparent transition duration-300 group-hover:opacity-90"
    />
    <div class="mt-6 flex grow flex-col gap-4">
      {
        post.data.callout && (
          <div class="flex justify-between gap-4">
            <div>
              <p
                class:list={twMerge(
                  post.data.callout.value.length < 6 ? 'text-3xl lg:text-4xl' : 'text-xl',
                  'leading-none font-medium text-neutral-950 lg:max-w-48 dark:text-neutral-50'
                )}
              >
                {post.data.callout.value}
              </p>
              <p class="mt-2 text-[13px] leading-none text-neutral-500">
                {post.data.callout.label}
              </p>
            </div>
            <CompanyLogo
              company={post.data.callout.company}
              class="mt-1 mr-1 h-5 w-auto shrink-0 text-neutral-950 dark:text-neutral-50"
            />
          </div>
        )
      }
      <h3 class="line-clamp-2 text-base font-medium text-neutral-950 dark:text-neutral-50">
        {post.data.title}
      </h3>
      <p
        class="mt-auto inline-flex items-center gap-0.5 text-[13px] leading-none text-neutral-500 transition group-hover:text-neutral-950 group-active:text-neutral-950 dark:group-hover:text-neutral-50 dark:group-active:text-neutral-50"
      >
        See how they did it
        <ChevronRightIcon class="transition group-hover:translate-x-0.5" size={12} />
      </p>
    </div>
  </a>
</article>
