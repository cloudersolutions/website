{
  "name": "website",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": "^24.0.0",
    "npm": ">=11"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview --port 3001",
    "astro": "astro",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "optimize-new-images": "source .env && git diff --name-only HEAD^ | grep -E '\\.(png|jpe?g)$' | xargs -I {} tinypng --key $TINYPNG_API_KEY '{}' -o '{}' || echo 'No new images to optimize'",
    "test": "playwright test"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.5",
    "change-case": "^5.4.4",
    "chart.js": "^4.5.1",
    "lucide-astro": "^0.556.0",
    "luxon": "^3.7.2",
    "posthog-js": "^1.384.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@rollup/plugin-yaml": "^5.0.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "astro-eslint-parser": "^1.4.0",
    "eslint": "^10.4.1",
    "eslint-plugin-astro": "^1.7.0",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0"
  }
}
